{
  "schema": 1,
  "id": "qwen3-next-80b-a3b-instruct",
  "name": "Qwen3-Next-80B-A3B-Instruct",
  "hf_repo": "Qwen/Qwen3-Next-80B-A3B-Instruct",
  "source_format": "native_bf16",
  "default_variant": "q4",
  "architecture": {
    "hidden_size": 2048,
    "num_hidden_layers": 48,
    "num_attention_heads": 16,
    "num_key_value_heads": 2,
    "head_dim": 256,
    "vocab_size": 151936,
    "rms_norm_eps": 1e-06,
    "num_experts": 512,
    "num_experts_per_tok": 10,
    "moe_intermediate_size": 512,
    "shared_expert_intermediate_size": 512,
    "full_attention_interval": 4,
    "linear_num_value_heads": 32,
    "linear_num_key_heads": 16,
    "linear_key_head_dim": 128,
    "linear_value_head_dim": 128,
    "linear_conv_kernel_dim": 4,
    "partial_rotary_factor": 0.25,
    "rope_theta": 10000000
  },
  "special_tokens": {
    "eos_1": 151645,
    "eos_2": 151643,
    "think_start": 151667,
    "think_end": 151668
  },
  "default_sampling_profile": "instruct",
  "sampling_profiles": {
    "thinking-general": {
      "label": "Thinking (general tasks)",
      "description": "Broader reasoning for open-ended prompts.",
      "temperature": 1.0,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 1.5,
      "repetition_penalty": 1.0,
      "reasoning": 1
    },
    "thinking-coding": {
      "label": "Thinking (precise coding)",
      "description": "More focused reasoning for implementation work.",
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 0.0,
      "repetition_penalty": 1.0,
      "reasoning": 1
    },
    "instruct": {
      "label": "Instruct (non-thinking)",
      "description": "Direct responses without hidden reasoning.",
      "temperature": 0.7,
      "top_p": 0.8,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 1.5,
      "repetition_penalty": 1.0,
      "reasoning": 0
    }
  },
  "shared_artifacts": {
    "vocab.bin": {
      "step": "export_tokenizer"
    },
    "bf16/mtp_weights.bin": {
      "step": "compile_native:bf16_mtp",
      "optional": true,
      "companions": [
        "bf16/mtp_weights.json"
      ]
    }
  },
  "variants": {
    "q4": {
      "display_name": "Qwen3-Next-80B-A3B-Instruct-4bit",
      "quantization": {
        "bits": 4,
        "group_size": 64
      },
      "legacy_ids": [
        "Qwen-Qwen3-Next-80B-A3B-Instruct"
      ],
      "artifacts": {
        "model_weights.bin": {
          "step": "compile_native:non_experts",
          "companions": [
            "model_weights.json"
          ]
        },
        "packed_experts/": {
          "step": "compile_native:experts",
          "per_layer": "moe_layers",
          "layout": "layout.json"
        },
        "packed_mtp_experts/": {
          "step": "compile_native:mtp_experts",
          "per_layer": "mtp_layers",
          "layout": "layout.json",
          "required_if": "mtp"
        },
        "vocab.bin": {
          "from_shared": "vocab.bin"
        },
        "bf16/": {
          "from_shared": "bf16/",
          "optional": true
        }
      }
    },
    "q8": {
      "display_name": "Qwen3-Next-80B-A3B-Instruct-8bit",
      "quantization": {
        "bits": 8,
        "group_size": 64
      },
      "legacy_ids": [
        "Qwen-Qwen3-Next-80B-A3B-Instruct-8bit"
      ],
      "artifacts": {
        "model_weights.bin": {
          "step": "compile_native:non_experts",
          "companions": [
            "model_weights.json"
          ]
        },
        "packed_experts/": {
          "step": "compile_native:experts",
          "per_layer": "moe_layers",
          "layout": "layout.json"
        },
        "packed_mtp_experts/": {
          "step": "compile_native:mtp_experts",
          "per_layer": "mtp_layers",
          "layout": "layout.json",
          "required_if": "mtp"
        },
        "vocab.bin": {
          "from_shared": "vocab.bin"
        },
        "bf16/": {
          "from_shared": "bf16/",
          "optional": true
        }
      }
    }
  },
  "mtp": {
    "default_predictions": 1,
    "num_hidden_layers": 1
  },
  "thinking_capable": false
}
