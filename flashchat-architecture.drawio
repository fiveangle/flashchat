        <mxCell id="p1" value="CMD1&#xa;attn proj +&#xa;GatedDeltaNet&#xa;(BLAS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="dp_pipe">
          <mxGeometry x="12" y="44" width="155" height="92" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="CMD2&#xa;o_proj + norm +&#xa;router +&#xa;shared expert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="dp_pipe">
          <mxGeometry x="187" y="44" width="155" height="92" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="I/O  pread&#xa;K active experts&#xa;from SSD&#xa;(OS page cache)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="dp_pipe">
          <mxGeometry x="362" y="44" width="155" height="92" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="CMD3  (deferred)&#xa;expert forward&#xa;(FMA dequant) +&#xa;MoE combine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="dp_pipe">
          <mxGeometry x="537" y="44" width="155" height="92" as="geometry" />
        </mxCell>
        <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="dp_pipe" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pe2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="dp_pipe" source="p2" target="p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pe3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="dp_pipe" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="dp_shaders" value="shaders.metal&#xa;4-bit dequant matvec / matmulN ( FMA, multi-row v5 ) · fused SwiGLU&#xa;RMSNorm · batched GPU attention ( Q·Kᵀ / softmax / scores·V ) · RoPE · MoE combine" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="dp">
