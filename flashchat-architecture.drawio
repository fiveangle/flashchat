        <mxCell id="dp_load" value="Load&#xa;parse resolved_models.json → g_cfg · open_weights() mmap ~5.5GB&#xa;build_mtp_cache · Metal init + compile shaders" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="dp">
          <mxGeometry x="20" y="116" width="720" height="64" as="geometry" />
        </mxCell>

        <mxCell id="dp_pipe" value="Per-token decode pipeline   ( × 60 layers: 45 GatedDeltaNet + 15 full-attn )" style="swimlane;rounded=0;whiteSpace=wrap;html=1;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="dp">
