        </mxCell>
        <mxCell id="cp_int" value="Integrity / storage&#xa;artifacts ( verify · .flashchat_artifacts.json )&#xa;status · offload ( archive / restore ) · migrate&#xa;server.guard_model_not_serving" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="cp">
          <mxGeometry x="20" y="346" width="680" height="96" as="geometry" />
        </mxCell>

        <mxCell id="dp" value="DATA PLANE — metal_infer/ (C · Obj-C · Metal):  run inference" style="swimlane;rounded=0;whiteSpace=wrap;html=1;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="940" y="350" width="760" height="510" as="geometry" />
        </mxCell>
        <mxCell id="dp_entry" value="Engine entry&#xa;infer.m ( --serve | --prompt | chat ) · chat.m · main.m&#xa;model_config.h ( g_cfg ) · tokenizer.h ( C BPE )" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;" vertex="1" parent="dp">
