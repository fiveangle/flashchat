        <mxCell id="title" value="Flashchat — 397B MoE inference on a laptop: Python control plane builds artifacts, C/Metal data plane runs them" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1450" height="30" as="geometry" />
        </mxCell>

