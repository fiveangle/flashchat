            echo "=== Model Not Supported ==="
            echo ""
            echo "Model '$model_id' is not in $(flashchat_get MODEL_CONFIG)."
            echo ""
            echo "Expert extraction cancelled."
            exit 0
        fi
    fi
    
    local expert_index_path="$model_path/flashchat/expert_index.json"
    if [ -f "$expert_index_path" ]; then
        echo "Using model-specific expert index: $expert_index_path"
    else
        echo "Expert index not found: $expert_index_path"
        echo "Generating expert index from model safetensors..."
        if ! run_python "$SCRIPT_DIR/scripts/generate_expert_index.py" --model "$model_path" --output "$model_path/flashchat"; then
            echo "ERROR: Expert index generation failed."
            return 1
        fi
        echo "Expert index generated successfully."
    fi
    
    echo ""
    echo "=== Extract Expert Weights ==="
    echo ""
    
    local size_4bit="218GB (203GiB)"
    echo "Available disk space:"
    df -h . | tail -1
    echo ""
    
    echo "Model: $model_path"
    echo "Expert index: $expert_index_path"
    echo ""
    
    echo "Choose expert extraction:"
    echo ""
    echo "  [4] 4-bit mode (~$size_4bit) - Full quality, tool calling supported"
    echo "  [Q] Quit"
    echo ""
    
    echo -n "Select option [4/Q]: "
    read -r REPLY
    echo ""
    
    if [[ "$REPLY" =~ ^[4]$ ]]; then
        :
    elif [[ $REPLY =~ ^[Qq]$ ]]; then
        echo "Run './flashchat' again when ready to extract expert weights."
        exit 0
    else
        echo "Invalid option."
        exit 1
    fi
    
    echo ""
    echo "Extracting 4-bit experts..."
    echo "Estimated time: 30-60 minutes."
    echo ""
    if ! run_python "$SCRIPT_DIR/scripts/repack_experts.py" --model-id "$(flashchat_get MODEL)" --index "$expert_index_path"; then
        echo "ERROR: 4-bit expert extraction failed."
        return 1
    fi
    echo "4-bit experts extracted successfully."
}

prompt_save_config() {
    local config_file
    config_file=$(flashchat_get CONFIG_FILE)
    
    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        if ! grep -q '^MODEL=' "$config_file" 2>/dev/null; then
            echo ""
            echo "Configuration is missing MODEL. Rewriting with current defaults..."
            flashchat_create_default_config
            echo "Config updated."
        fi
        return
    fi
    
    echo ""
    echo "=== Save Settings? ==="
    echo ""
    echo "Would you like to save these settings to a config file?"
    echo "This allows you to skip these prompts on future runs."
    read -p "Save to config? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        flashchat_create_default_config
        echo "Config saved to ~/.config/flashchat/config"
    fi
    echo ""
}

check_xcode_cli() {
    if xcode-select -p >/dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

prompt_install_xcode_cli() {
    echo ""
    echo "========================================"
    echo "  Ready to install tools for Flashchat?"
    echo "========================================"
    show_dependency_overview
    echo "  (X to exit the setup wizard)"
    read -p "Begin downloading the needed tools? [Y/x] " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Xx]$ ]]; then
        echo "User cancelled."
        echo "Re-run flashchat to begin the setup wizard."
        exit 0
    fi
    if ! [[ $REPLY =~ ^[Yy]$ ]] && [ -n "$REPLY" ]; then
        echo "Invalid selection. Re-run flashchat and choose Y or X."
        exit 1
    fi

    if ! check_homebrew; then
        if ! bootstrap_homebrew_noninteractive; then
            echo "Homebrew installation failed."
            echo "Continuing with Xcode CLI tools installation."
        fi
    fi

    echo ""
    echo "=== Xcode Command Line Tools Required ==="
    echo ""
    echo "Flashchat requires Xcode command line tools to compile the inference engine."
    echo "Without it, the model cannot run."
    echo ""
    read -p "Would you like to install Xcode CLI tools now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        echo "Installing Xcode command line tools..."
        echo "(This may prompt for your password)"
        xcode-select --install || true
        echo ""
        echo "If prompted in another window, choose default options."
        echo "Waiting for Xcode CLI tools to become available..."
        for _ in $(seq 1 120); do
            if check_xcode_cli; then
                echo "Xcode command line tools detected."
                return 0
            fi
            sleep 5
        done
        echo "Xcode CLI tools are still not detected."
        echo "Please finish installation, then run flashchat again."
        exit 0
    else
        echo "Cannot proceed without Xcode CLI tools. Exiting."
        exit 1
    fi
}

ensure_setup() {
    local force="${1:-0}"
    
    set +e  # Temporarily disable exit on error for setup checks
    flashchat_load_config
    
    logv "Checking setup status..."
    
    # Check for Xcode CLI tools first (required for building)
    if ! check_xcode_cli; then
        prompt_install_xcode_cli
    fi
    
    # Check model - loop until model is available or user cancels
    while ! check_model_downloaded; do
        if check_model_extracted; then
            break
        fi
        prompt_download_model
        flashchat_load_config
    done

    # Re-load config after model download (path may have changed)
    flashchat_load_config
    
    # Check weights
    if ! check_weights_extracted; then
        prompt_extract_weights
    fi
    
    # Check vocab
    if ! check_vocab_exported; then
        prompt_export_vocab
    fi
    
    # Check experts - always prompt if force mode, or if not extracted
    if [ "$force" = "1" ]; then
        # Force mode: show current status and offer to re-extract
        echo ""
        echo "=== Expert Weights Status ==="
        echo ""
        if check_experts_extracted; then
            echo "Experts: extracted"
        else
            echo "Experts: NOT extracted"
        fi
        
        echo ""
        read -p "Re-extract experts? [y/N] " -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            prompt_extract_experts
        fi
    else
        if ! check_experts_extracted; then
            prompt_extract_experts
        fi
    fi
    
    prompt_save_config
    
    logv "Setup complete."
    
    set -e  # Re-enable exit on error
}

# -----------------------------------------------------------------------------
# Server management
# -----------------------------------------------------------------------------

is_server_running() {
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

is_server_healthy() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    curl -fsS --max-time 2 "http://${host}:${port}/health" >/dev/null 2>&1
}

wait_for_server() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    local max_wait=30
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        if nc -z "$host" "$port" 2>/dev/null && is_server_healthy "$port"; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_pid_exit() {
    local pid="$1"
    local timeout="${2:-10}"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_port_clear() {
    local port="$1"
    local timeout="${2:-10}"
    local host
    host="$(flashchat_server_connect_host)"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! is_port_listening "$port"; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

get_port_listener_pid() {
    local port="$1"
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -Fp 2>/dev/null | awk '/^p/ { print substr($0, 2); exit }'
}

get_port_listener_command() {
    local port="$1"
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -Fc 2>/dev/null | awk '/^c/ { print substr($0, 2); exit }'
}

is_port_listening() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    if nc -z "$host" "$port" 2>/dev/null; then
        return 0
    fi
    [ -n "$(get_port_listener_pid "$port")" ]
}

is_flashchat_infer_command() {
    local command_name="$1"
    case "$command_name" in
        infer|metal_infer/infer|*/metal_infer/infer|*/infer)
            return 0
            ;;
    esac
    return 1
}

stop_external_server() {
    local server_port="$1"
    local force="$2"
    local pid command_name

    pid=$(get_port_listener_pid "$server_port")
    command_name=$(get_port_listener_command "$server_port")

    if [ -z "$pid" ]; then
        echo "Server port $server_port is in use but the owning process could not be found."
        echo "Use 'lsof -i :$server_port' to inspect it manually."
        return 1
    fi

    if ! is_flashchat_infer_command "$command_name"; then
        echo "Refusing to stop the process listening on port $server_port."
        echo "It does not look like Flashchat's infer server: ${command_name:-unknown} (PID: $pid)"
        return 1
    fi

    echo "Stopping external Flashchat server (PID: $pid, command: $command_name)..."
    kill "$pid" 2>/dev/null || true
    if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
        echo "External server stopped."
        return 0
    fi

    if [ "$force" -eq 1 ]; then
        echo "External server did not exit after waiting. Sending SIGKILL..."
        kill -9 "$pid" 2>/dev/null || true
        if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
            echo "External server force-stopped."
            return 0
        fi
        error "External server process $pid is still present after SIGKILL"
    fi

    echo "External server is still running after SIGTERM."
    echo "Try: flashchat serve --stop --external --force"
    return 1
}

find_available_port() {
    local start_port="$1"
    local port="$start_port"
    local host
    host="$(flashchat_server_connect_host)"
    
    while [ $port -lt $((start_port + 10)) ]; do
        if ! is_port_listening "$port"; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    
    echo "$start_port"
    return 1
}

resolve_model_blob_target() {
    local path="$1"
    if [ -L "$path" ]; then
        local target
        local dir
        dir=$(dirname "$path")
        target=$(readlink "$path")
        if [[ "$target" != /* ]]; then
            target="$dir/$target"
        fi
        (
            cd "$(dirname "$target")" 2>/dev/null || exit 1
            printf "%s/%s\n" "$(pwd -P)" "$(basename "$target")"
        )
        return
    fi
    printf "%s\n" "$path"
}

list_model_blob_targets() {
    local model_path="$1"
    local path
    for path in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
        [ -e "$path" ] || continue
        resolve_model_blob_target "$path"
    done | awk '!seen[$0]++'
}

bytes_to_human() {
    local bytes="$1"
    awk -v bytes="$bytes" '
        function human(x) {
            split("B KiB MiB GiB TiB PiB", u, " ")
            i = 1
            while (x >= 1024 && i < 6) {
                x /= 1024
                i++
            }
            if (i == 1) return sprintf("%d %s", x, u[i])
            return sprintf("%.1f %s", x, u[i])
        }
        BEGIN { print human(bytes) }
    '
}

get_model_blobs_size() {
    local model_path="$1"
    local total=0
    local target
    while IFS= read -r target; do
        [ -f "$target" ] || continue
        local size
        size=$(stat -f %z "$target" 2>/dev/null || echo 0)
        total=$((total + size))
    done < <(list_model_blob_targets "$model_path")
    if [ "$total" -gt 0 ]; then
        bytes_to_human "$total"
    fi
}

delete_model_blobs() {
    local model_path="$1"
    local path
    local deleted=0

    while IFS= read -r path; do
        [ -e "$path" ] || continue
        local target
        target=$(resolve_model_blob_target "$path")
        if [ -n "$target" ] && [ -f "$target" ]; then
            rm -f "$target"
            deleted=1
        fi
        rm -f "$path"
    done < <(
        for path in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
            [ -e "$path" ] || continue
            printf "%s\n" "$path"
        done
    )

    if [ "$deleted" -eq 1 ]; then
        return 0
    fi
    return 1
}

cmd_serve() {
    local stop=0
    local force=0
    local external=0
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stop)
                stop=1
                shift
                ;;
            --stop-external)
                stop=1
                external=1
                shift
                ;;
            --external)
                external=1
                shift
                ;;
            --force)
                force=1
                shift
                ;;
            -p|--port)
                port="$2"
                shift 2
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done
    
    if [ "$stop" -eq 1 ]; then
        flashchat_load_config
        set +m  # Disable job control to suppress termination messages
        local pid_file
        local server_port
        pid_file=$(flashchat_get_pid_file)
        server_port="${port:-$(flashchat_get SERVER_PORT)}"

        if [ -f "$pid_file" ]; then
            local pid
            pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                echo "Stopping server (PID: $pid)..."
                kill "$pid" 2>/dev/null
                if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
                    rm -f "$pid_file"
                    echo "Server stopped."
                elif [ "$force" -eq 1 ]; then
                    echo "Server did not exit after waiting. Sending SIGKILL..."
                    kill -9 "$pid" 2>/dev/null || true
                    if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
                        rm -f "$pid_file"
                        echo "Server force-stopped."
                    else
                        error "Server process $pid is still present after SIGKILL"
                    fi
                else
                    echo "Server is still running after SIGTERM."
                    echo "Try: flashchat serve --stop --force"
                    return 1
                fi
            else
                echo "Server not running (stale PID file)."
                rm -f "$pid_file"
            fi
        elif is_port_listening "$server_port"; then
            if [ "$external" -eq 1 ]; then
                stop_external_server "$server_port" "$force"
            else
                echo "An external server is listening on port $server_port."
                echo "Use 'flashchat serve --stop --external' to stop it after confirming it is Flashchat's infer server."
                return 1
            fi
        else
            echo "No server running."
        fi
        return
    fi
    
    # Start server
    flashchat_load_config
    
    # Verify model is available before starting server
    if ! check_model_downloaded; then
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before starting the server."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before starting the server."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    # Check if WE already started the server
    if is_server_running; then
        echo "Server is already running (PID: $(cat $(flashchat_get_pid_file))."
        return
    fi
    
    # Check if port is available (may be used by another process)
    if is_port_listening "$server_port"; then
        echo "Port $server_port is in use by another process."
        local suggested
        suggested=$(find_available_port $((server_port + 1)))
        echo "Suggested available port: $suggested"
        read -p "Use port $suggested instead? [Y/n] " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
            server_port="$suggested"
        else
            error "Cannot start server on port $server_port"
        fi
    fi
    
    # Start server in background
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    
    ensure_binaries
    
    # Set environment for infer
    export FLASHCHAT_MODEL_PATH="$(flashchat_get MODEL_PATH)"
    export FLASHCHAT_SERVER_PORT="$server_port"
    export FLASHCHAT_TEMPERATURE="$(flashchat_get TEMPERATURE)"
    export FLASHCHAT_TOP_P="$(flashchat_get TOP_P)"
    export FLASHCHAT_MODEL="$(flashchat_get MODEL)"
    export FLASHCHAT_SERVER_LOG="$(flashchat_get SERVER_LOG_PATH)"
    export FLASHCHAT_SERVER_DEBUG="$(flashchat_get SERVER_DEBUG)"
    export FLASHCHAT_SERVER_HTTP_LOG="$(flashchat_get SERVER_HTTP_LOG)"
    export FLASHCHAT_SESSIONS_DIR="$(flashchat_get_sessions_dir)"
    export FLASHCHAT_SYSTEM_PROMPT="$(flashchat_get_system_prompt_file)"
    export FLASHCHAT_MODEL_CONFIG="$(flashchat_get MODEL_CONFIG)"

    "$SCRIPT_DIR/metal_infer/infer" --serve "$server_port" > /dev/null 2>&1 &
    local infer_pid=$!
    
    # Wait for server to be ready
    echo "Starting server on port $server_port..."
    if wait_for_server "$server_port"; then
        echo "$infer_pid" > "$pid_file"
        echo "Server running (PID: $infer_pid)"
        echo "API available at http://$server_host:$server_port"
        echo ""
        echo "Endpoints:"
        echo "  POST /v1/chat/completions"
        echo "  POST /v1/responses"
        echo "  GET  /v1/models"
        echo "  GET  /health"
        echo ""
        echo "To stop: flashchat serve --stop"
    else
        error "Server failed to start"
    fi
}

cmd_chat() {
    local resume_id=""
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume)
                resume_id="$2"
                shift 2
                ;;
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    # Verify model is available before starting chat
    if ! check_model_downloaded; then
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before starting chat."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before starting chat."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    # Start server if not running
    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Launch chat
    ensure_binaries
    local old_pwd
    old_pwd="$(pwd)"
    cd "$SCRIPT_DIR/metal_infer"
    
    local chat_args=""
    [ -n "$server_port" ] && chat_args="--port $server_port"
    [ -n "$server_host" ] && chat_args="$chat_args --host $server_host"
    export FLASHCHAT_MODEL="$(flashchat_get MODEL)"
    export FLASHCHAT_SERVER_HOST="$server_host"
    export FLASHCHAT_SESSIONS_DIR="$(flashchat_get_sessions_dir)"
    export FLASHCHAT_HISTORY_FILE="$(flashchat_get_history_file)"
    [ -n "$resume_id" ] && chat_args="$chat_args --resume $resume_id"
    
    ./chat $chat_args
    
    cd "$old_pwd"
}

cmd_prompt() {
    local prompt="$1"
    
    if [ -z "$prompt" ]; then
        error "Usage: flashchat prompt \"your message here\""
    fi
    
    flashchat_load_config
    
    # Verify model is available before running prompt
    if ! check_model_downloaded; then
        # Check if original HF model exists but not extracted
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before running prompts."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before running prompts."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port=$(flashchat_get SERVER_PORT)
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    # Start server if not running
    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Wait for server
    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi
    
    # Send request
    curl -s -N -X POST "http://$server_host:$server_port/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"role\":\"user\",\"content\":\"$prompt\"}],\"max_tokens\":$(flashchat_get MAX_TOKENS),\"temperature\":$(flashchat_get TEMPERATURE),\"top_p\":$(flashchat_get TOP_P)}"
    echo ""
}

cmd_opencode() {
    local port=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done

    flashchat_load_config

    if ! command -v opencode >/dev/null 2>&1; then
        error "OpenCode CLI not found in PATH"
    fi

    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"

    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi

    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi

    if ! check_opencode_config "$server_port" "$server_host"; then
        error "OpenCode config is missing or incomplete"
    fi

    echo "Launching OpenCode against http://${server_host}:${server_port}/v1"
    cd "$SCRIPT_DIR"
    opencode "$@"
}

