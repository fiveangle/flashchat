get_last_layer_index() {
    local model_id
    model_id=$(flashchat_get MODEL)
    local model_config
    model_config=$(flashchat_get MODEL_CONFIG)
    if [ -f "$model_config" ] && command -v python3 >/dev/null 2>&1; then
        python3 -c "import json; data=json.load(open('$model_config')); layers=data.get('models',{}).get('$model_id',{}).get('num_hidden_layers',60); print(layers-1)" 2>/dev/null
    else
        echo "59"
    fi
}

check_model_downloaded() {
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    local weights_dir
    weights_dir=$(flashchat_get WEIGHTS_DIR)
    if [[ "$weights_dir" != /* ]]; then
        weights_dir="${weights_dir#./}"
        weights_dir="${SCRIPT_DIR}/$weights_dir"
    fi
    
    if ! [ -f "$weights_dir/model_weights.bin" ] || \
       ! [ -f "$weights_dir/model_weights.json" ] || \
       ! [ -f "$weights_dir/vocab.bin" ]; then
        return 1
    fi
    
    local last_layer
    last_layer=$(get_last_layer_index)
    local experts_dir
    experts_dir=$(flashchat_get EXPERTS_DIR)
    [ -f "$experts_dir/layer_${last_layer}.bin" ] && return 0
    
    return 1
}

check_model_extracted() {
    local model_path
    model_path=$(flashchat_get MODEL_PATH)

    # Check if original HuggingFace model exists (safetensors)
    # Use glob to match any shard pattern (e.g., model-00001-of-00004, model-00001-of-00046)
    for f in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
        [ -f "$f" ] && return 0
    done
    [ -f "$model_path/config.json" ] && return 0
    return 1
}

