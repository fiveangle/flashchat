# -----------------------------------------------------------------------------
# Prompt for all config options
# -----------------------------------------------------------------------------
prompt_config_options() {
    # Try to read from tty if available, otherwise use defaults
    if [ -t 0 ]; then
        prompt_config_interactive
    else
        # Non-interactive: use defaults
        echo ""
        echo "=== Configuration Settings ==="
        echo "(Running in non-interactive mode - using defaults)"
        echo ""
        
        local default_repo default_quant default_tokens default_temp
        local default_top_p default_port default_host default_log_path default_debug default_http_log default_think default_color
        
        default_repo=$(flashchat_get MODEL_REPO)
        default_quant=$(flashchat_get QUANTIZATION)
        default_tokens=$(flashchat_get MAX_TOKENS)
        default_temp=$(flashchat_get TEMPERATURE)
        default_top_p=$(flashchat_get TOP_P)
        default_port=$(flashchat_get SERVER_PORT)
        default_host=$(flashchat_get SERVER_HOST)
        default_log_path=$(flashchat_get SERVER_LOG_PATH)
        default_debug=$(flashchat_get SERVER_DEBUG)
        default_http_log=$(flashchat_get SERVER_HTTP_LOG)
        default_think=$(flashchat_get SHOW_THINKING)
        default_color=$(flashchat_get COLOR_OUTPUT)
        
        # Create config file with defaults
        flashchat_create_default_config
        
        echo "Using all defaults."
    fi
}

prompt_config_interactive() {
    rm -f /tmp/flashchat_new_config
    touch /tmp/flashchat_new_config
    
    echo "(Press Enter to accept default)"
    echo ""
    
    # Model Repository
    local default_repo
    default_repo=$(flashchat_get MODEL_REPO)
    printf "Model repository [%s]: " "$default_repo"
    read -r REPLY
    echo "MODEL_REPO=\"${REPLY:-$default_repo}\"" >> /tmp/flashchat_new_config
    
    # Experts quantization
    local default_quant
    default_quant=$(flashchat_get QUANTIZATION)
    local selected_quant=""
    printf "Experts quantization (2/4 for 2bit/4bit) [%s]: " "$default_quant"
    read -r selected_quant
    selected_quant="${selected_quant:-$default_quant}"
    # Convert shortcuts: 2 -> 2bit, 4 -> 4bit
    if [ "$selected_quant" = "2" ]; then
        selected_quant="2bit"
    elif [ "$selected_quant" = "4" ]; then
        selected_quant="4bit"
    fi
    
    # Check if 2bit is selected and verify experts exist
    if [ "$selected_quant" = "2bit" ]; then
        if ! check_experts_2bit_extracted; then
            echo ""
            echo "=== 2-bit Experts Not Found ==="
            echo ""
            echo "The 2-bit experts have not been extracted yet."
            echo "You can extract them now, or use 4-bit mode instead."
            echo ""
            read -p "Extract 2-bit experts now? [Y/n] " -n 1 -r
            echo ""
            
            if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
                local num_workers
                num_workers=$(get_performance_cores)
                echo "Extracting 2-bit experts using $num_workers parallel workers..."
                cd "$SCRIPT_DIR/metal_infer"
                run_python repack_experts_2bit.py --workers "$num_workers"
                cd "$SCRIPT_DIR"
                
                if check_experts_2bit_extracted; then
                    echo "2-bit experts extracted successfully."
                else
                    echo "ERROR: Failed to extract 2-bit experts. Reverting to 4bit."
                    selected_quant="4bit"
                fi
            else
                echo "Cancelled. Reverting to 4bit."
                selected_quant="4bit"
            fi
        fi
    fi
    
    echo "QUANTIZATION=\"$selected_quant\"" >> /tmp/flashchat_new_config
    
    # Max Tokens
    local default_tokens
    default_tokens=$(flashchat_get MAX_TOKENS)
    printf "Context window limit [%s]: " "$default_tokens"
    read -r REPLY
    echo "MAX_TOKENS=\"${REPLY:-$default_tokens}\"" >> /tmp/flashchat_new_config
    
    # Temperature
    local default_temp
    default_temp=$(flashchat_get TEMPERATURE)
    printf "Temperature (0.0-2.0) [randomness - higher=creative, lower=focused] [%s]: " "$default_temp"
    read -r REPLY
    echo "TEMPERATURE=\"${REPLY:-$default_temp}\"" >> /tmp/flashchat_new_config
    
    # Top P
    local default_top_p
    default_top_p=$(flashchat_get TOP_P)
    printf "Top-p (0.0-1.0) [nucleus sampling - lower=focused, higher=diverse] [%s]: " "$default_top_p"
    read -r REPLY
    echo "TOP_P=\"${REPLY:-$default_top_p}\"" >> /tmp/flashchat_new_config
    
    # Server Port
    local default_port
    default_port=$(flashchat_get SERVER_PORT)
    printf "Server port [%s]: " "$default_port"
    read -r REPLY
    echo "SERVER_PORT=\"${REPLY:-$default_port}\"" >> /tmp/flashchat_new_config
    
    # Server Host
    local default_host
    default_host=$(flashchat_get SERVER_HOST)
    printf "Server host [%s]: " "$default_host"
    read -r REPLY
    echo "SERVER_HOST=\"${REPLY:-$default_host}\"" >> /tmp/flashchat_new_config

    # Server Log Path
    local default_log_path
    default_log_path=$(flashchat_get SERVER_LOG_PATH)
    printf "Server log path (file or directory) [%s]: " "$default_log_path"
    read -r REPLY
    echo "SERVER_LOG_PATH=\"${REPLY:-$default_log_path}\"" >> /tmp/flashchat_new_config

    # Server Debug
    local default_debug
    default_debug=$(flashchat_get SERVER_DEBUG)
    printf "Server debug logging artifacts (0/1) [%s]: " "$default_debug"
    read -r REPLY
    echo "SERVER_DEBUG=\"${REPLY:-$default_debug}\"" >> /tmp/flashchat_new_config

    # Server HTTP Log
    local default_http_log
    default_http_log=$(flashchat_get SERVER_HTTP_LOG)
    printf "Server HTTP traffic log (0/1) [%s]: " "$default_http_log"
    read -r REPLY
    echo "SERVER_HTTP_LOG=\"${REPLY:-$default_http_log}\"" >> /tmp/flashchat_new_config

    # Show Thinking
    local default_think
    default_think=$(flashchat_get SHOW_THINKING)
    printf "Show thinking tokens (0/1) [%s]: " "$default_think"
    read -r REPLY
    echo "SHOW_THINKING=\"${REPLY:-$default_think}\"" >> /tmp/flashchat_new_config
    
    # Color Output
    local default_color
    default_color=$(flashchat_get COLOR_OUTPUT)
    printf "Color output (0/1) [%s]: " "$default_color"
    read -r REPLY
    echo "COLOR_OUTPUT=\"${REPLY:-$default_color}\"" >> /tmp/flashchat_new_config
    
    # Save config only if changed
    local old_config
    old_config=$(cat "$(flashchat_get CONFIG_FILE)")
    local new_config
    new_config=$(cat /tmp/flashchat_new_config)
    rm -f /tmp/flashchat_new_config
    
    if [ "$old_config" = "$new_config" ]; then
        echo "No changes made."
    else
        echo "$new_config" > "$(flashchat_get CONFIG_FILE)"
        echo "Configuration updated."
    fi
}

# -----------------------------------------------------------------------------
# Auto-setup functions
# -----------------------------------------------------------------------------

check_model_downloaded() {
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    local weights_dir
    weights_dir=$(flashchat_get WEIGHTS_DIR)
    local quantization
    quantization=$(flashchat_get QUANTIZATION)
    
    if [[ "$weights_dir" != /* ]]; then
        weights_dir="${weights_dir#./}"
        weights_dir="${SCRIPT_DIR}/$weights_dir"
    fi
    
    if ! [ -f "$weights_dir/model_weights.bin" ] || \
       ! [ -f "$weights_dir/model_weights.json" ] || \
       ! [ -f "$weights_dir/vocab.bin" ]; then
        return 1
    fi
    
    if [ "$quantization" = "2bit" ]; then
        local experts_2bit_dir
        experts_2bit_dir=$(flashchat_get EXPERTS_2BIT_DIR)
        [ -f "$experts_2bit_dir/layer_59.bin" ] && return 0
    else
        local experts_dir
        experts_dir=$(flashchat_get EXPERTS_DIR)
        [ -f "$experts_dir/layer_59.bin" ] && return 0
    fi
    
    return 1
}

check_model_extracted() {
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    
    # Check if original HuggingFace model exists (safetensors)
    [ -f "$model_path/model-00001-of-00046.safetensors" ] || \
    [ -f "$model_path/model.safetensors" ] || \
    [ -f "$model_path/config.json" ]
    return $?
}

prompt_extract_setup() {
    echo ""
    echo "=== Model Files Required ==="
    echo ""
    echo "The model has been downloaded but the following need to be extracted:"
    echo "  - Non-expert weights (~5.5GB): model_weights.bin + model_weights.json"
    echo "  - Vocabulary: vocab.bin"
    echo "  - Expert weights (4-bit or 2-bit): packed_experts/"
    echo ""
    echo "This is a ONE-TIME setup operation."
    read -p "Run extraction now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        ensure_setup
    else
        echo "Extraction cancelled. Run 'flashchat' again when ready."
        exit 0
    fi
}

FLASHCHAT_VENV=""

ensure_venv() {
    if [ -n "$FLASHCHAT_VENV" ] && [ -f "$FLASHCHAT_VENV/bin/python" ]; then
        if "$FLASHCHAT_VENV/bin/python" -c "import numpy" >/dev/null 2>&1; then
            return 0
        fi
        echo "NumPy missing from existing virtual environment. Installing..."
        "$FLASHCHAT_VENV/bin/pip" install numpy -q
        return 0
    fi
    
    FLASHCHAT_VENV="$SCRIPT_DIR/metal_infer/.venv"
    
    if [ ! -f "$FLASHCHAT_VENV/bin/python" ]; then
        echo "Creating Python virtual environment..."
        python3 -m venv "$FLASHCHAT_VENV"
    fi

    if ! "$FLASHCHAT_VENV/bin/python" -c "import numpy" >/dev/null 2>&1; then
        echo "Installing NumPy in project virtual environment..."
        "$FLASHCHAT_VENV/bin/pip" install numpy -q
    fi
}

run_python() {
    ensure_venv
    "$FLASHCHAT_VENV/bin/python" "$@"
}

check_binaries() {
    [ -f "$SCRIPT_DIR/metal_infer/infer" ] && [ -f "$SCRIPT_DIR/metal_infer/chat" ]
    return $?
}

ensure_binaries() {
    if check_binaries; then
        return 0
    fi
    
    echo "Binaries not found. Building..."
    local old_pwd
    old_pwd="$(pwd)"
    cd "$SCRIPT_DIR/metal_infer"
    make all chat
    cd "$old_pwd"
    
    if check_binaries; then
        echo "Build complete."
    else
        echo "ERROR: Build failed."
        exit 1
    fi
}

check_weights_extracted() {
    local weights_dir
    weights_dir=$(flashchat_get WEIGHTS_DIR)
    if [[ "$weights_dir" != /* ]]; then
        weights_dir="${weights_dir#./}"
        weights_dir="${SCRIPT_DIR}/$weights_dir"
    fi
    [ -f "$weights_dir/model_weights.bin" ] && [ -f "$weights_dir/model_weights.json" ]
    return $?
}

check_vocab_exported() {
    local weights_dir
    weights_dir=$(flashchat_get WEIGHTS_DIR)
    if [[ "$weights_dir" != /* ]]; then
        weights_dir="${weights_dir#./}"
        weights_dir="${SCRIPT_DIR}/$weights_dir"
    fi
    [ -f "$weights_dir/vocab.bin" ]
    return $?
}

check_experts_extracted() {
    local experts_dir
    experts_dir=$(flashchat_get EXPERTS_DIR)
    if [[ "$experts_dir" != /* ]]; then
        experts_dir="${experts_dir#./}"
        experts_dir="${SCRIPT_DIR}/$experts_dir"
    fi
    [ -f "$experts_dir/layer_59.bin" ]
    return $?
}

check_experts_2bit_extracted() {
    local experts_2bit_dir
    experts_2bit_dir=$(flashchat_get EXPERTS_2BIT_DIR)
    if [[ "$experts_2bit_dir" != /* ]]; then
        experts_2bit_dir="${experts_2bit_dir#./}"
        experts_2bit_dir="${SCRIPT_DIR}/$experts_2bit_dir"
    fi
    [ -f "$experts_2bit_dir/layer_59.bin" ]
    return $?
}

get_performance_cores() {
    local p_cores
    p_cores=$(sysctl -n hw.perflevel0.physicalcpu 2>/dev/null)
    if [ -n "$p_cores" ] && [ "$p_cores" -gt 0 ]; then
        # Comment line below out to risk minor multithreaded extraction fragmentation
        p_cores="1" 
        echo "$p_cores"
    else
        echo "1"
    fi
}

check_hf_cli() {
    if command -v hf &> /dev/null; then
        return 0
    else
        return 1
    fi
}

check_homebrew() {
    if command -v brew &> /dev/null; then
        return 0
    fi
    return 1
}

get_macos_version_label() {
    local version
    version=$(sw_vers -productVersion 2>/dev/null)
    local major="${version%%.*}"
    local codename="Unknown"

    case "$major" in
        11) codename="Big Sur" ;;
        12) codename="Monterey" ;;
        13) codename="Ventura" ;;
        14) codename="Sonoma" ;;
        15) codename="Sequoia" ;;
    esac

    if [ -n "$version" ]; then
        echo "macOS $version ($codename)"
    else
        echo "macOS (version unavailable)"
    fi
}

show_dependency_overview() {
    local os_label
    os_label=$(get_macos_version_label)
    local brew_version
    if check_homebrew; then
        brew_version=$(brew --version 2>/dev/null | head -1)
    else
        brew_version="Not installed yet"
    fi

    echo ""
    echo "=== Setup Dependencies ==="
    echo ""
    echo "Homebrew: package manager for macOS."
    echo "  Trusted open-source package manager for $os_label"
    echo "  Status: $brew_version"
    echo "  Repo: https://github.com/Homebrew/brew (47k stars, 11k forks as of 2026-04)"
    echo ""
    echo "Apple Xcode CLI: tools to build macOS and iOS apps from the command line."
    echo "  If prompted in another window, choose the default install options."
    echo ""
    echo "Hugging Face Hub utility for model download: https://huggingface.co"
    echo "  Installed in a temporary Python virtual environment and removed after model download."
    echo ""
    echo "NumPy: numerical computing library for Python: https://numpy.org"
    echo "  Installed in the project Python virtual environment for extraction/repack scripts."
    echo ""
}

bootstrap_homebrew_noninteractive() {
    if check_homebrew; then
        return 0
    fi

    echo "Homebrew is not installed."
    echo "Installing Homebrew automatically (NONINTERACTIVE=1)..."

    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi

    if check_homebrew; then
        echo "Homebrew installed successfully."
        return 0
    fi

    echo "ERROR: Homebrew install did not complete successfully."
    return 1
}

prompt_download_model() {
    local model_repo
    model_repo=$(flashchat_get MODEL_REPO)
    
    echo ""
    echo "=== Model Download Required ==="
    echo ""
    echo "Model not found: $model_repo"
    echo ""
    echo "Would you like to download it from HuggingFace?"
    echo "This may take 30+ minutes depending on your internet connection."
    read -p "Download now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        echo "Downloading model..."
        
        if check_hf_cli; then
            echo "Using Homebrew hf CLI..."
            hf model download "$model_repo"
        else
            echo "Installing huggingface-hub in temporary venv..."
            HF_VENV="/tmp/hf_$$"
            python3 -m venv "$HF_VENV"
            "$HF_VENV/bin/pip" install huggingface-hub -q 2>/dev/null
            "$HF_VENV/bin/python" -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='$model_repo')"
            rm -rf "$HF_VENV"
        fi
        
        echo "Download complete."
    else
        echo "Download cancelled. Run 'flashchat' again when ready."
        exit 0
    fi
}

