#!/bin/bash
# flashchat — Flashchat Unified Management CLI
#
# Usage:
#   flashchat [command] [options]
#
# Commands:
#   chat              Start chat (auto-sets up if missing)
#   chat --resume ID  Resume session
#   opencode          Launch OpenCode against the local Flashchat server
#   serve             Start API server (auto-sets up if missing)
#   serve --stop      Stop running server
#   serve --stop --external  Stop external Flashchat server on configured port
#   prompt "..."      Single prompt (auto-sets up if missing)
#   config            Edit/show configuration
#   models            List supported models and setup status
#   manage            Manage local/offloaded model storage
#   status            Show system status
#   sessions          List sessions
#   help              Show this help
#
# Options:
#   --config FILE     Use specific config
#   -v, --verbose    Verbose output
#   -q, --quiet      Quiet mode
#
# Configuration:
#   Config is loaded from (priority highest to lowest):
#     1. --config FILE (explicit override)
#     2. ~/.config/flashchat/config (user)
#     3. Environment variables (FLASHCHAT_*)
#     4. Registry/default values

set -e
set +m  # Disable job control messages

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib/config.sh"

# Global flags
VERBOSE=0
QUIET=0
CONFIG_FILE=""

# -----------------------------------------------------------------------------
# Helper functions
# -----------------------------------------------------------------------------

log() {
    [ "$QUIET" -eq 0 ] && echo "$@"
}

logv() {
    [ "$VERBOSE" -eq 1 ] && echo "[DEBUG] $@"
}

error() {
    echo "ERROR: $@" >&2
    exit 1
}

current_quantization_label() {
    local model_id bits
    model_id=$(flashchat_get MODEL)
    bits=$(flashchat_model_quant_bits "$model_id")
    bits="${bits:-4}"
    echo "${bits}-bit"
}

flashchat_set_config_value() {
    local key="$1"
    local value="$2"
    local config_file
    config_file="$(flashchat_get CONFIG_FILE)"
    mkdir -p "$(dirname "$config_file")"
    if [ -f "$config_file" ] && grep -qE "^${key}=" "$config_file"; then
        sed -i '' "s/^${key}=.*/${key}=\"${value}\"/" "$config_file"
    else
        printf '%s="%s"\n' "$key" "$value" >> "$config_file"
    fi
}

confirm_show_thinking_for_chat() {
    local reasoning show_thinking
    reasoning="$(flashchat_get REASONING)"
    show_thinking="$(flashchat_get SHOW_THINKING)"
    if [ "$reasoning" != "1" ] || [ "$show_thinking" = "1" ]; then
        return 0
    fi

    local model_id quant profile_id profile_label profile reply
    model_id="$(flashchat_get MODEL)"
    quant="$(current_quantization_label)"
    profile_id="$(flashchat_get SAMPLING_PROFILE)"
    profile_id="${profile_id:-custom}"
    profile_label="$(flashchat_model_sampling_profile_field "$model_id" "$profile_id" "label" 2>/dev/null || true)"
    if [ -n "$profile_label" ] && [ "$profile_label" != "$profile_id" ]; then
        profile="${profile_label} (${profile_id})"
    else
        profile="$profile_id"
    fi

    echo ""
    echo "${model_id}, ${quant}, ${profile}"
    echo ""
    echo "Enables Thinking, but your personal settings have \"Show Thinking\" disabled."
    echo "Would you like to enable Show Thinking?"
    echo ""
    echo "  [y] Yes, enable Show Thinking"
    echo "  [N] No, keep it hidden"
    echo "  [x] Exit to previous menu"
    if ! read -p "> " -n 1 -r reply; then
        reply=""
    fi
    echo ""

    case "$reply" in
        y|Y)
            flashchat_set_config_value "SHOW_THINKING" "1"
            SHOW_THINKING="1"
            echo "Show Thinking enabled."
            ;;
        x|X)
            echo "Returning to the previous menu."
            return 2
            ;;
        *)
            echo "Show Thinking will stay disabled."
            ;;
    esac
    return 0
}

mtp_label() {
    local v="$1"
    case "$v" in
        "") echo "registry default" ;;
        1) echo "automatic" ;;
        0) echo "disabled" ;;
        *[!0-9]*) echo "automatic ($v)" ;;
        *) echo "batch size $v" ;;
    esac
}

normalize_server_log_path() {
    local path="$1"
    [ -z "$path" ] && return
    case "$path" in
        */) echo "$path" ;;
        *)
            local base="${path##*/}"
            if [[ "$base" = *.* ]]; then
                echo "$path"
            else
                echo "${path}/"
            fi
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Parse global options
# -----------------------------------------------------------------------------
parse_global_opts() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            --config)
                CONFIG_FILE="$2"
                FLASHCHAT_CONFIG_FILE_OVERRIDE="$2"
                export FLASHCHAT_CONFIG_FILE_OVERRIDE
                shift 2
                ;;
            --model)
                export FLASHCHAT_MODEL="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done
}

