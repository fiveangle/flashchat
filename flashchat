check_xcode_cli() {
    if xcode-select -p >/dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

prompt_install_xcode_cli() {
    echo ""
    echo "========================================"
    echo "  Ready to install tools for Flashchat?"
    echo "========================================"
    show_dependency_overview
    echo "  (X to exit the setup wizard)"
    read -p "Begin downloading the needed tools? [Y/x] " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Xx]$ ]]; then
        echo "User cancelled."
        echo "Re-run flashchat to begin the setup wizard."
        exit 0
    fi
    if ! [[ $REPLY =~ ^[Yy]$ ]] && [ -n "$REPLY" ]; then
        echo "Invalid selection. Re-run flashchat and choose Y or X."
        exit 1
    fi

    if ! check_homebrew; then
        if ! bootstrap_homebrew_noninteractive; then
            echo "Homebrew installation failed."
            echo "Continuing with Xcode CLI tools installation."
        fi
    fi

    echo ""
    echo "=== Xcode Command Line Tools Required ==="
    echo ""
    echo "Flashchat requires Xcode command line tools to compile the inference engine."
    echo "Without it, the model cannot run."
    echo ""
    read -p "Would you like to install Xcode CLI tools now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        echo "Installing Xcode command line tools..."
        echo "(This may prompt for your password)"
        xcode-select --install || true
        echo ""
        echo "If prompted in another window, choose default options."
        echo "Waiting for Xcode CLI tools to become available..."
        for _ in $(seq 1 120); do
            if check_xcode_cli; then
                echo "Xcode command line tools detected."
                return 0
            fi
            sleep 5
        done
        echo "Xcode CLI tools are still not detected."
        echo "Please finish installation, then run flashchat again."
        exit 0
    else
        echo "Cannot proceed without Xcode CLI tools. Exiting."
        exit 1
    fi
}

ensure_setup() {
    local force="${1:-0}"
    
    set +e  # Temporarily disable exit on error for setup checks
    flashchat_load_config
    
    logv "Checking setup status..."
    
    # Check for Xcode CLI tools first (required for building)
    if ! check_xcode_cli; then
        prompt_install_xcode_cli
    fi
    
    # Check model
    if ! check_model_downloaded; then
        prompt_download_model
    fi
    
    # Re-load config after model download (path may have changed)
    flashchat_load_config
    
    # Check weights
    if ! check_weights_extracted; then
        prompt_extract_weights
    fi
    
    # Check vocab
    if ! check_vocab_exported; then
        prompt_export_vocab
    fi
    
    # Check experts - always prompt if force mode, or if not extracted
    local quantization
    quantization=$(flashchat_get QUANTIZATION)
    
    if [ "$force" = "1" ]; then
        # Force mode: show current status and offer to re-extract
        echo ""
        echo "=== Expert Weights Status ==="
        echo ""
        echo "Current quantization: $quantization"
        echo ""
        
        if [ "$quantization" = "2bit" ]; then
            if check_experts_2bit_extracted; then
                echo "2-bit experts: extracted"
            else
                echo "2-bit experts: NOT extracted"
            fi
        else
            if check_experts_extracted; then
                echo "4-bit experts: extracted"
            else
                echo "4-bit experts: NOT extracted"
            fi
        fi
        
        echo ""
        read -p "Re-extract experts? [y/N] " -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            prompt_extract_experts
        fi
    elif [ "$quantization" = "2bit" ]; then
        if ! check_experts_2bit_extracted; then
            # For 2bit, we need 4bit first
            if ! check_experts_extracted; then
                prompt_extract_experts
            else
                # 4bit exists, just need 2bit
                local num_workers
                num_workers=$(get_performance_cores)
                cd "$SCRIPT_DIR/metal_infer"
                run_python repack_experts_2bit.py --workers "$num_workers"
                cd "$SCRIPT_DIR"
            fi
        fi
    else
        if ! check_experts_extracted; then
            prompt_extract_experts
        fi
    fi
    
    prompt_save_config
    
    logv "Setup complete."
    
    set -e  # Re-enable exit on error
}

# -----------------------------------------------------------------------------
# Server management
# -----------------------------------------------------------------------------

is_server_running() {
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

is_server_healthy() {
    local port="$1"
    curl -fsS --max-time 2 "http://127.0.0.1:${port}/health" >/dev/null 2>&1
}

wait_for_server() {
    local port="$1"
    local max_wait=30
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        if nc -z 127.0.0.1 "$port" 2>/dev/null && is_server_healthy "$port"; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_pid_exit() {
    local pid="$1"
    local timeout="${2:-10}"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_port_clear() {
    local port="$1"
    local timeout="${2:-10}"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! nc -z 127.0.0.1 "$port" 2>/dev/null; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

find_available_port() {
    local start_port="$1"
    local port="$start_port"
    
    while [ $port -lt $((start_port + 10)) ]; do
        if ! nc -z 127.0.0.1 "$port" 2>/dev/null; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    
    echo "$start_port"
    return 1
}

resolve_model_blob_target() {
    local path="$1"
    if [ -L "$path" ]; then
        local target
        local dir
        dir=$(dirname "$path")
        target=$(readlink "$path")
        if [[ "$target" != /* ]]; then
            target="$dir/$target"
        fi
        (
            cd "$(dirname "$target")" 2>/dev/null || exit 1
            printf "%s/%s\n" "$(pwd -P)" "$(basename "$target")"
        )
        return
    fi
    printf "%s\n" "$path"
}

list_model_blob_targets() {
    local model_path="$1"
    local path
    for path in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
        [ -e "$path" ] || continue
        resolve_model_blob_target "$path"
    done | awk '!seen[$0]++'
}

bytes_to_human() {
    local bytes="$1"
    awk -v bytes="$bytes" '
        function human(x) {
            split("B KiB MiB GiB TiB PiB", u, " ")
            i = 1
            while (x >= 1024 && i < 6) {
                x /= 1024
                i++
            }
            if (i == 1) return sprintf("%d %s", x, u[i])
            return sprintf("%.1f %s", x, u[i])
        }
        BEGIN { print human(bytes) }
    '
}

get_model_blobs_size() {
    local model_path="$1"
    local total=0
    local target
    while IFS= read -r target; do
        [ -f "$target" ] || continue
        local size
        size=$(stat -f %z "$target" 2>/dev/null || echo 0)
        total=$((total + size))
    done < <(list_model_blob_targets "$model_path")
    if [ "$total" -gt 0 ]; then
        bytes_to_human "$total"
    fi
}

delete_model_blobs() {
    local model_path="$1"
    local path
    local deleted=0

    while IFS= read -r path; do
        [ -e "$path" ] || continue
        local target
        target=$(resolve_model_blob_target "$path")
        if [ -n "$target" ] && [ -f "$target" ]; then
            rm -f "$target"
            deleted=1
        fi
        rm -f "$path"
    done < <(
        for path in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
            [ -e "$path" ] || continue
            printf "%s\n" "$path"
        done
    )

    if [ "$deleted" -eq 1 ]; then
        return 0
    fi
    return 1
}

cmd_serve() {
    local stop=0
    local force=0
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stop)
                stop=1
                shift
                ;;
            --force)
                force=1
                shift
                ;;
            -p|--port)
                port="$2"
                shift 2
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done
    
    if [ "$stop" -eq 1 ]; then
        flashchat_load_config
        set +m  # Disable job control to suppress termination messages
        local pid_file
        local server_port
        pid_file=$(flashchat_get_pid_file)
        server_port="${port:-$(flashchat_get SERVER_PORT)}"

        if [ -f "$pid_file" ]; then
            local pid
            pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                echo "Stopping server (PID: $pid)..."
                kill "$pid" 2>/dev/null
                if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
                    rm -f "$pid_file"
                    echo "Server stopped."
                elif [ "$force" -eq 1 ]; then
                    echo "Server did not exit after waiting. Sending SIGKILL..."
                    kill -9 "$pid" 2>/dev/null || true
                    if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
                        rm -f "$pid_file"
                        echo "Server force-stopped."
                    else
                        error "Server process $pid is still present after SIGKILL"
                    fi
                else
                    echo "Server is still running after SIGTERM."
                    echo "Try: flashchat serve --stop --force"
                    return 1
                fi
            else
                echo "Server not running (stale PID file)."
                rm -f "$pid_file"
            fi
        elif nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
            local pid
            pid=$(lsof -ti:"$server_port" 2>/dev/null | head -1)
            if [ -n "$pid" ]; then
                echo "Stopping external server (PID: $pid)..."
                kill "$pid" 2>/dev/null
                if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
                    echo "External server stopped."
                elif [ "$force" -eq 1 ]; then
                    echo "External server did not exit after waiting. Sending SIGKILL..."
                    kill -9 "$pid" 2>/dev/null || true
                    if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
                        echo "External server force-stopped."
                    else
                        error "External server process $pid is still present after SIGKILL"
                    fi
                else
                    echo "External server is still running after SIGTERM."
                    echo "Try: flashchat serve --stop --force"
                    return 1
                fi
            else
                echo "Server port $server_port is in use but the owning process could not be found."
                echo "Use 'lsof -i :$server_port' to inspect it manually."
            fi
        else
            echo "No server running."
        fi
        return
    fi
    
    # Start server
    flashchat_load_config
    
    # Verify model is available before starting server
    if ! check_model_downloaded; then
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before starting the server."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before starting the server."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    
    # Check if WE already started the server
    if is_server_running; then
        echo "Server is already running (PID: $(cat $(flashchat_get_pid_file))."
        return
    fi
    
    # Check if port is available (may be used by another process)
    if nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Port $server_port is in use by another process."
        local suggested
        suggested=$(find_available_port $((server_port + 1)))
        echo "Suggested available port: $suggested"
        read -p "Use port $suggested instead? [Y/n] " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
            server_port="$suggested"
        else
            error "Cannot start server on port $server_port"
        fi
    fi
    
    # Start server in background
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    
    ensure_binaries
    cd "$SCRIPT_DIR/metal_infer"
    
    # Set environment for infer
    export FLASHCHAT_MODEL_PATH="$(flashchat_get MODEL_PATH)"
    export FLASHCHAT_SERVER_PORT="$server_port"
    export FLASHCHAT_QUANTIZATION="$(flashchat_get QUANTIZATION)"
    export FLASHCHAT_TEMPERATURE="$(flashchat_get TEMPERATURE)"
    export FLASHCHAT_TOP_P="$(flashchat_get TOP_P)"
    export FLASHCHAT_SERVER_LOG="$(flashchat_get SERVER_LOG_PATH)"
    export FLASHCHAT_SERVER_DEBUG="$(flashchat_get SERVER_DEBUG)"
    export FLASHCHAT_SERVER_HTTP_LOG="$(flashchat_get SERVER_HTTP_LOG)"
    
    # Start server (redirect output to avoid mixing with TUI)
    ./infer --serve "$server_port" > /dev/null 2>&1 &
    local infer_pid=$!
    
    cd "$SCRIPT_DIR"
    
    # Wait for server to be ready
    echo "Starting server on port $server_port..."
    if wait_for_server "$server_port"; then
        echo "$infer_pid" > "$pid_file"
        echo "Server running (PID: $infer_pid)"
        echo "API available at http://127.0.0.1:$server_port"
        echo ""
        echo "Endpoints:"
        echo "  POST /v1/chat/completions"
        echo "  POST /v1/responses"
        echo "  GET  /v1/models"
        echo "  GET  /health"
        echo ""
        echo "To stop: flashchat serve --stop"
    else
        error "Server failed to start"
    fi
}

cmd_chat() {
    local resume_id=""
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume)
                resume_id="$2"
                shift 2
                ;;
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    # Verify model is available before starting chat
    if ! check_model_downloaded; then
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before starting chat."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before starting chat."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    
    # Start server if not running
    if ! nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Launch chat
    ensure_binaries
    cd "$SCRIPT_DIR/metal_infer"
    
    local chat_args=""
    [ -n "$server_port" ] && chat_args="--port $server_port"
    [ -n "$resume_id" ] && chat_args="$chat_args --resume $resume_id"
    
    ./chat $chat_args
    
    cd "$SCRIPT_DIR"
}

cmd_prompt() {
    local prompt="$1"
    
    if [ -z "$prompt" ]; then
        error "Usage: flashchat prompt \"your message here\""
    fi
    
    flashchat_load_config
    
    # Verify model is available before running prompt
    if ! check_model_downloaded; then
        # Check if original HF model exists but not extracted
        if check_model_extracted; then
            echo ""
            echo "=== Model Not Extracted ==="
            echo ""
            echo "The model is downloaded but not extracted for inference."
            echo "Extraction is required before running prompts."
            echo ""
            prompt_extract_setup
        else
            echo ""
            echo "=== Model Not Found ==="
            echo ""
            echo "The configured model is not in the HuggingFace cache."
            echo "Download is required before running prompts."
            echo ""
            prompt_download_model
        fi
    fi
    
    local server_port
    server_port=$(flashchat_get SERVER_PORT)
    
    # Start server if not running
    if ! nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Wait for server
    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi
    
    # Send request
    curl -s -N -X POST "http://127.0.0.1:$server_port/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"role\":\"user\",\"content\":\"$prompt\"}],\"max_tokens\":$(flashchat_get MAX_TOKENS),\"temperature\":$(flashchat_get TEMPERATURE),\"top_p\":$(flashchat_get TOP_P)}"
    echo ""
}

cmd_opencode() {
    local port=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done

    flashchat_load_config

    if ! command -v opencode >/dev/null 2>&1; then
        error "OpenCode CLI not found in PATH"
    fi

    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"

    if ! nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi

    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi

    if ! check_opencode_config "$server_port"; then
        error "OpenCode config is missing or incomplete"
    fi

    echo "Launching OpenCode against http://127.0.0.1:${server_port}/v1"
    cd "$SCRIPT_DIR"
    opencode "$@"
}

# -----------------------------------------------------------------------------
# Interactive menu
# -----------------------------------------------------------------------------
interactive_menu() {
    flashchat_load_config
    
    # Check if config exists
    if [ ! -f "$(flashchat_get CONFIG_FILE)" ]; then
        echo "Welcome to Flashchat. Running initial setup..."
        ensure_setup
    else
        # Config exists - verify model is available, download if missing
        if ! check_model_downloaded; then
            if check_model_extracted; then
                echo ""
                echo "=== Model Not Extracted ==="
                echo ""
                echo "The model is downloaded but not extracted for inference."
                echo "Extraction is required before running."
                echo ""
                prompt_extract_setup
            else
                echo ""
                echo "=== Model Not Found ==="
                echo ""
                echo "The configured model is not in the HuggingFace cache."
                echo "Downloading is required before running."
                echo ""
                prompt_download_model
            fi
        fi
    fi
    
    while true; do
        flashchat_load_config
        
        local server_status="Not running"
        if is_server_running; then
            server_status="Running"
        elif nc -z 127.0.0.1 "$(flashchat_get SERVER_PORT)" 2>/dev/null; then
            server_status="Running (external)"
        fi
        
        # Detect if model is set up
        local setup_status="Not ready"
        if check_model_downloaded && check_weights_extracted && check_vocab_exported && check_experts_extracted; then
            setup_status="Ready"
        fi
        
        local server_url="http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)/v1"
        
        local server_line="Server: $server_status"
        if [ "$server_status" = "Running" ] || [ "$server_status" = "Running (external)" ]; then
            server_line="$server_line   API: $server_url"
        fi
        
        echo ""
        echo "=================================================="
        echo "           Flashchat Management"
        echo "=================================================="
        echo "Status: $setup_status at $server_url"
        echo "Model: $(flashchat_get MODEL_REPO) ($(flashchat_get QUANTIZATION))"
        echo "$server_line"
        echo "[N]ew [D]ialog, Server [O]n/[O]ff, [S]how [C]onfig, [M]odels, [Q]uit"
        read -p "> " -n 1 -r
        
        case "$REPLY" in
            n|N)
                echo ""
                cmd_chat
                ;;
            d|D)
                echo ""
                echo "Select a chat dialog to resume:"
                echo ""
                
                # Get sessions list
                local sessions_dir
                sessions_dir=$(flashchat_get_sessions_dir)
                
                if [ ! -d "$sessions_dir" ]; then
                    echo "  (no chat dialogs found)"
                    echo ""
                else
                    local count=0
                    local session_ids=()
                    
                    for f in "$sessions_dir"/*.jsonl; do
                        [ -f "$f" ] || continue
                        local session_id
                        session_id=$(basename "$f" .jsonl)
                        local lines
                        lines=$(wc -l < "$f")
                        count=$((count + 1))
                        session_ids+=("$session_id")
                        echo "  [$count] $session_id ($lines turns)"
                    done
                    
                    if [ $count -eq 0 ]; then
                        echo "  (no chat dialogs)"
                    else
                        echo ""
                        echo -n "Enter number or chat dialog ID: "
                        read -r session_id
                        
                        # Check if input is a number
                        if [[ "$session_id" =~ ^[0-9]+$ ]] && [ "$session_id" -le $count ] && [ "$session_id" -gt 0 ]; then
                            session_id="${session_ids[$((session_id - 1))]}"
                        fi
                        
                        if [ -n "$session_id" ]; then
                            cmd_chat --resume "$session_id"
                        fi
                    fi
                fi
                ;;
            s|S)
                echo ""
                cmd_status
                ;;
            o|O)
                echo ""
                if is_server_running; then
                    if ! cmd_serve --stop; then
                        read -p "Server is not responding. Force stop the server? [Y/n] " -n 1 -r
                        echo ""
                        if [[ $REPLY =~ ^[Nn]$ ]]; then
                            :
                        else
                            cmd_serve --stop --force
                        fi
                    fi
                else
                    cmd_serve
                fi
                ;;
            c|C)
                cmd_config_interactive
                ;;
            m|M)
                echo ""
                cmd_clean
                ;;
            q|Q)
                echo ""
                echo "Goodbye!"
                break
                ;;
            *)
                echo ""
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Command: clean
# -----------------------------------------------------------------------------
cmd_clean() {
    flashchat_load_config
    
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    local quantization
    quantization=$(flashchat_get QUANTIZATION)
    
    while true; do
        echo "=== Clean Model Files ==="
        echo ""
        echo "Current model: $(flashchat_get MODEL_REPO)"
        echo ""
        
        # Original Hugging Face model shards
        local blobs_size=""
        blobs_size=$(get_model_blobs_size "$model_path")
        
        # Packed experts (4-bit)
        local experts_dir="$model_path/packed_experts"
        local experts_size=""
        if [ -d "$experts_dir" ]; then
            experts_size=$(du -sh "$experts_dir" 2>/dev/null | cut -f1)
        fi
        
        # Packed experts 2-bit
        local experts_2bit_dir="$model_path/packed_experts_2bit"
        local experts_2bit_size=""
        if [ -d "$experts_2bit_dir" ]; then
            experts_2bit_size=$(du -sh "$experts_2bit_dir" 2>/dev/null | cut -f1)
        fi
        
        echo "Removable directories:"
        echo ""
        
        # Show numbered list with descriptions
        if [ -n "$blobs_size" ]; then
            echo "  [1] $blobs_size - model blobs (needed only to extract 4bit quants)"
        else
            echo "  [1] (empty) - model blobs"
        fi
        
        if [ -n "$experts_size" ]; then
            echo "  [2] $experts_size - packed_experts (needed to run 4bit quant and extract 2bit quants)"
        else
            echo "  [2] (empty) - packed_experts"
        fi
        
        if [ -n "$experts_2bit_size" ]; then
            echo "  [3] $experts_2bit_size - packed_experts_2bit (needed to run 2bit quant)"
        else
            echo "  [3] (empty) - packed_experts_2bit"
        fi
        
        echo ""
        echo "Enter numbers to delete (e.g., 1,3), [Q]uit to exit: "
        read -r REPLY
        
        if [[ "$REPLY" =~ ^[Qq]$ ]] || [ -z "$REPLY" ]; then
            echo "Done."
            return
        fi
        
        # Process each selected number
        local deleted=0
        
        for num in $(echo "$REPLY" | tr ',' ' '); do
            case "$num" in
                1)
                    if [ -n "$blobs_size" ]; then
                        if delete_model_blobs "$model_path"; then
                            echo "Deleted model blobs."
                            deleted=1
                        fi
                    fi
                    ;;
                2)
                    if [ -n "$experts_size" ]; then
                        # Warn if current quant is 4bit
                        if [ "$quantization" = "4bit" ]; then
                            echo ""
                            echo "WARNING: Your config currently uses 4bit quantization."
                            echo "Deleting packed_experts will prevent the server from running."
                            read -p "Delete anyway? [y/N] " -n 1 -r
                            echo ""
                            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                                echo "Skipped."
                                continue
                            fi
                        fi
                        rm -rf "$experts_dir"
                        echo "Deleted packed_experts."
                        deleted=1
                    fi
                    ;;
                3)
                    if [ -n "$experts_2bit_size" ]; then
                        # Warn if current quant is 2bit
                        if [ "$quantization" = "2bit" ]; then
                            echo ""
                            echo "WARNING: Your config currently uses 2bit quantization."
                            echo "Deleting packed_experts_2bit will prevent the server from running."
                            read -p "Delete anyway? [y/N] " -n 1 -r
                            echo ""
                            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                                echo "Skipped."
                                continue
                            fi
                        fi
                        rm -rf "$experts_2bit_dir"
                        echo "Deleted packed_experts_2bit."
                        deleted=1
                    fi
                    ;;
            esac
        done
        
        if [ "$deleted" -eq 0 ]; then
            echo "No valid directories selected."
        fi
        
        echo ""
    done
}

# -----------------------------------------------------------------------------
# Command: benchmark
# -----------------------------------------------------------------------------
cmd_benchmark() {
    local target=""
    
    if [ $# -eq 0 ]; then
        echo "=== Available Benchmarks ==="
        echo ""
        echo "  run         - Single expert forward pass"
        echo "  verify      - Metal vs CPU reference verification"
        echo "  bench       - Benchmark single expert (10 iterations)"
        echo "  moe         - Full MoE forward (K experts, single layer)"
        echo "  moebench    - Benchmark MoE (10 iterations)"
        echo "  full        - Full 60-layer forward (K=4)"
        echo "  fullbench   - Benchmark full forward (3 iterations)"
        echo ""
        echo "Usage: flashchat benchmark <target>"
        echo "Example: flashchat benchmark fullbench"
        return
    fi
    
    target="$1"
    
    # Load config and export environment variables
    flashchat_load_config
    export FLASHCHAT_MODEL_PATH="$(flashchat_get MODEL_PATH)"
    export FLASHCHAT_WEIGHTS_DIR="$(flashchat_get WEIGHTS_DIR)"
    export FLASHCHAT_EXPERTS_DIR="$(flashchat_get EXPERTS_DIR)"
    export FLASHCHAT_QUANTIZATION="$(flashchat_get QUANTIZATION)"
    
    cd "$SCRIPT_DIR/metal_infer"
    ensure_binaries
    
    case "$target" in
        run)
            echo "Running: single expert forward pass..."
            make run
            ;;
        verify)
            echo "Running: Metal vs CPU verification..."
            make verify
            ;;
        bench)
            echo "Running: single expert benchmark (10 iterations)..."
            make bench
            ;;
        moe)
            echo "Running: MoE forward (K experts, single layer)..."
            make moe
            ;;
        moebench)
            echo "Running: MoE benchmark (10 iterations)..."
            make moebench
            ;;
        full)
            echo "Running: Full 60-layer forward (K=4)..."
            make full
            ;;
        fullbench)
            echo "Running: Full benchmark (3 iterations)..."
            make fullbench
            ;;
        *)
            echo "Unknown benchmark: $target"
            echo "Run 'flashchat benchmark' to see available targets."
            ;;
    esac
    
    cd "$SCRIPT_DIR"
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    parse_global_opts "$@"
    
    # If no command, show interactive menu
    if [ $# -eq 0 ]; then
        interactive_menu
        return
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h)
            show_help
            ;;
        status)
            cmd_status "$@"
            ;;
        sessions)
            cmd_sessions "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        chat)
            ensure_setup
            cmd_chat "$@"
            ;;
        serve)
            cmd_serve "$@"
            ;;
        prompt)
            ensure_setup
            cmd_prompt "$@"
            ;;
        opencode)
            ensure_setup
            cmd_opencode "$@"
            ;;
        benchmark)
            cmd_benchmark "$@"
            ;;
        *)
            error "Unknown command: $command"
            ;;
    esac
}

main "$@"
