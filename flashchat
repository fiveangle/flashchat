prompt_extract_experts() {
    local quantization
    quantization=$(flashchat_get QUANTIZATION)
    
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    local model_repo
    model_repo=$(flashchat_get MODEL_REPO)
    
    # Check if model is supported
    if [[ "$model_repo" != *"Qwen3.5-397B-A17B"* ]]; then
        echo ""
        echo "=== Model Not Supported ==="
        echo ""
        echo "Currently, only Qwen3.5-397B-A17B is supported."
        echo "The selected model '$model_repo' has a different architecture"
        echo "and is not compatible with this inference engine."
        echo ""
        echo "Supported model: mlx-community/Qwen3.5-397B-A17B-4bit"
        echo ""
        echo "Expert extraction cancelled."
        exit 0
    fi
    
    local expert_index_path=""
    if [ -f "$model_path/expert_index.json" ]; then
        expert_index_path="$model_path/expert_index.json"
        echo "Using model-specific expert index: $expert_index_path"
    else
        expert_index_path="./expert_index.json"
        echo "Using local expert index: $expert_index_path"
    fi
    
    echo ""
    echo "=== Extract Expert Weights ==="
    echo ""
    
    local size_4bit="218GB (203GiB)"
    local size_2bit="121GB (113GiB)"
    
    echo "Available disk space:"
    df -h . | tail -1
    echo ""
    
    echo "Model: $model_path"
    echo "Expert index: $expert_index_path"
    echo ""
    
    echo "Choose quantization mode:"
    echo ""
    echo "  [4] 4-bit mode (~$size_4bit) - Full quality, tool calling supported"
    echo "  [2] 2-bit mode (+~$size_2bit, requires 4-bit first) - Faster but breaks tool calling"
    echo "  [Q] Quit"
    echo ""
    
    echo -n "Select option [4/2/Q]: "
    read -r REPLY
    echo ""
    
    local extraction_mode=""
    if [[ "$REPLY" =~ ^[4]$ ]]; then
        extraction_mode="4bit"
    elif [[ $REPLY =~ ^[2]$ ]]; then
        extraction_mode="2bit"
    elif [[ $REPLY =~ ^[Qq]$ ]]; then
        echo "Run './flashchat' again when ready to extract expert weights."
        exit 0
    else
        echo "Invalid option."
        exit 1
    fi
    
    # Update config with selection
    local config_file
    config_file=$(flashchat_get CONFIG_FILE)
    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        sed -i '' "s/QUANTIZATION=.*/QUANTIZATION=\"$extraction_mode\"/" "$config_file"
    fi
    export FLASHCHAT_QUANTIZATION="$extraction_mode"
    
    if [ "$extraction_mode" = "4bit" ]; then
        echo ""
        echo "Extracting 4-bit experts..."
        echo "Estimated time: 30-60 minutes."
        echo ""
        cd "$SCRIPT_DIR"
        if ! run_python repack_experts.py --index "$expert_index_path"; then
            echo "ERROR: 4-bit expert extraction failed."
            return 1
        fi
        echo "4-bit experts extracted successfully."
    elif [ "$extraction_mode" = "2bit" ]; then
        echo ""
        echo "First extracting 4-bit experts..."
        cd "$SCRIPT_DIR"
        if ! run_python repack_experts.py --index "$expert_index_path"; then
            echo "ERROR: 4-bit expert extraction failed."
            return 1
        fi
        
        echo ""
        echo "Requantizing to 2-bit..."
        echo "Estimated time: 15-30 minutes."
        echo ""
        local num_workers
        num_workers=$(get_performance_cores)
        echo "Using $num_workers parallel workers..."
        cd "$SCRIPT_DIR/metal_infer"
        if ! run_python repack_experts_2bit.py --workers "$num_workers"; then
            echo "ERROR: 2-bit requantization failed."
            return 1
        fi
        echo "2-bit experts created successfully."
    fi
}

