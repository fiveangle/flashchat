interactive_menu() {
    flashchat_load_config
    
    # Check if config exists
    if [ ! -f "$(flashchat_get CONFIG_FILE)" ]; then
        echo "Welcome to Flashchat. Running initial setup..."
        ensure_setup
    else
        # Config exists - verify model is available, download if missing
        if ! check_model_downloaded; then
            if check_model_extracted; then
                echo ""
                echo "=== Model Not Extracted ==="
                echo ""
                echo "The model is downloaded but not extracted for inference."
                echo "Extraction is required before running."
                echo ""
                prompt_extract_setup
            else
                echo ""
                echo "=== Model Not Found ==="
                echo ""
                echo "The configured model is not in the HuggingFace cache."
                echo "Downloading is required before running."
                echo ""
                prompt_download_model
            fi
        fi
    fi
    
    while true; do
        flashchat_load_config
        
        local server_status="Not running"
        if is_server_running; then
            server_status="Running"
        elif is_port_listening "$(flashchat_get SERVER_PORT)"; then
            server_status="Running (external)"
        fi
        
        # Detect if model is set up
        local setup_status="Not ready"
        if check_model_downloaded && check_weights_extracted && check_vocab_exported && check_experts_extracted; then
            setup_status="Ready"
        fi
        
        local server_url="http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)/v1"
        
        local server_line="Server: $server_status"
        if [ "$server_status" = "Running" ] || [ "$server_status" = "Running (external)" ]; then
            server_line="$server_line   API: $server_url"
        fi
        
        echo ""
        echo "=================================================="
        echo "           Flashchat Management"
        echo "=================================================="
        echo "Status: $setup_status at $server_url"
        echo "Model: $(flashchat_get MODEL)"
        echo "$server_line"
        echo "[N]ew [D]ialog, Server [O]n/[O]ff, [S]how [C]onfig, [M]anage, [Q]uit"
        read -p "> " -n 1 -r
        
        case "$REPLY" in
            n|N)
                echo ""
                cmd_chat
                ;;
            d|D)
                echo ""
                echo "Select a chat dialog to resume:"
                echo ""
                
                # Get sessions list
                local sessions_dir
                sessions_dir=$(flashchat_get_sessions_dir)
                
                if [ ! -d "$sessions_dir" ]; then
                    echo "  (no chat dialogs found)"
                    echo ""
                else
                    local count=0
                    local session_ids=()
                    
                    for f in "$sessions_dir"/*.jsonl; do
                        [ -f "$f" ] || continue
                        local session_id
                        session_id=$(basename "$f" .jsonl)
                        local lines
                        lines=$(wc -l < "$f")
                        count=$((count + 1))
                        session_ids+=("$session_id")
                        echo "  [$count] $session_id ($lines turns)"
                    done
                    
                    if [ $count -eq 0 ]; then
                        echo "  (no chat dialogs)"
                    else
                        echo ""
                        echo -n "Enter number or chat dialog ID: "
                        read -r session_id
                        
                        # Check if input is a number
                        if [[ "$session_id" =~ ^[0-9]+$ ]] && [ "$session_id" -le $count ] && [ "$session_id" -gt 0 ]; then
                            session_id="${session_ids[$((session_id - 1))]}"
                        fi
                        
                        if [ -n "$session_id" ]; then
                            cmd_chat --resume "$session_id"
                        fi
                    fi
                fi
                ;;
            s|S)
                echo ""
                cmd_status
                ;;
            o|O)
                echo ""
                if is_server_running; then
                    if ! cmd_serve --stop; then
                        read -p "Server is not responding. Force stop the server? [Y/n] " -n 1 -r
                        echo ""
                        if [[ $REPLY =~ ^[Nn]$ ]]; then
                            :
                        else
                            cmd_serve --stop --force
                        fi
                    fi
                elif [ "$server_status" = "Running (external)" ]; then
                    echo "A server is already listening at $(flashchat_server_connect_host):$(flashchat_get SERVER_PORT), but Flashchat does not own its pid file."
                    read -p "Stop this external Flashchat server? [y/N] " -n 1 -r
                    echo ""
                    if [[ $REPLY =~ ^[Yy]$ ]]; then
                        if ! cmd_serve --stop --external; then
                            read -p "External server did not stop cleanly. Force stop it? [y/N] " -n 1 -r
                            echo ""
                            if [[ $REPLY =~ ^[Yy]$ ]]; then
                                cmd_serve --stop --external --force
                            fi
                        fi
                    fi
                else
                    cmd_serve
                fi
                ;;
            c|C)
                cmd_config_interactive
                ;;
            m|M)
                echo ""
                cmd_manage
                ;;
            q|Q)
                echo ""
                echo "Goodbye!"
                break
                ;;
            *)
                echo ""
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Command: clean
# -----------------------------------------------------------------------------
cmd_clean() {
    flashchat_load_config
    
    local model_path
    model_path=$(flashchat_get MODEL_PATH)
    while true; do
        echo "=== Clean Model Files ==="
        echo ""
        echo "Current model: $(flashchat_get MODEL)"
        echo ""
        
        # Original Hugging Face model shards
        local blobs_size=""
        blobs_size=$(get_model_blobs_size "$model_path")
        
        # Packed experts (4-bit)
        local experts_dir="$model_path/flashchat/packed_experts"
        if [ ! -d "$experts_dir" ]; then
            experts_dir="$model_path/packed_experts"
        fi
        local experts_size=""
        if [ -d "$experts_dir" ]; then
            experts_size=$(du -sh "$experts_dir" 2>/dev/null | cut -f1)
        fi
        
        echo "Removable directories:"
        echo ""
        
        # Show numbered list with descriptions
        if [ -n "$blobs_size" ]; then
            echo "  [1] $blobs_size - model blobs (needed only to extract experts)"
        else
            echo "  [1] (empty) - model blobs"
        fi
        
        if [ -n "$experts_size" ]; then
            echo "  [2] $experts_size - packed_experts (needed to run the model)"
        else
            echo "  [2] (empty) - packed_experts"
        fi
        
        echo ""
        echo "Enter numbers to delete (e.g., 1,2), [Q]uit to exit: "
        read -r REPLY
        
        if [[ "$REPLY" =~ ^[Qq]$ ]] || [ -z "$REPLY" ]; then
            echo "Done."
            return
        fi
        
        # Process each selected number
        local deleted=0
        
        for num in $(echo "$REPLY" | tr ',' ' '); do
            case "$num" in
                1)
                    if [ -n "$blobs_size" ]; then
                        if delete_model_blobs "$model_path"; then
                            echo "Deleted model blobs."
                            deleted=1
                        fi
                    fi
                    ;;
                2)
                    if [ -n "$experts_size" ]; then
                        echo ""
                        echo "WARNING: Deleting packed_experts will prevent the server from running."
                        read -p "Delete anyway? [y/N] " -n 1 -r
                        echo ""
                        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                            echo "Skipped."
                            continue
                        fi
                        rm -rf "$experts_dir"
                        echo "Deleted packed_experts."
                        deleted=1
                    fi
                    ;;
            esac
        done
        
        if [ "$deleted" -eq 0 ]; then
            echo "No valid directories selected."
        fi
        
        echo ""
    done
}

# -----------------------------------------------------------------------------
# Command: benchmark
# -----------------------------------------------------------------------------
cmd_benchmark() {
    local target=""
    
    if [ $# -eq 0 ]; then
        echo "=== Available Benchmarks ==="
        echo ""
        echo "  run         - Single expert forward pass"
        echo "  verify      - Metal vs CPU reference verification"
        echo "  bench       - Benchmark single expert (10 iterations)"
        echo "  moe         - Full MoE forward (K experts, single layer)"
        echo "  moebench    - Benchmark MoE (10 iterations)"
        echo "  full        - Full model forward (K=4)"
        echo "  fullbench   - Benchmark full forward (3 iterations)"
        echo ""
        echo "Usage: flashchat benchmark <target>"
        echo "Example: flashchat benchmark fullbench"
        return
    fi
    
    target="$1"
    
    # Load config and export environment variables
    flashchat_load_config
    export FLASHCHAT_MODEL_PATH="$(flashchat_get MODEL_PATH)"
    export FLASHCHAT_WEIGHTS_DIR="$(flashchat_get WEIGHTS_DIR)"
    export FLASHCHAT_EXPERTS_DIR="$(flashchat_get EXPERTS_DIR)"
    export FLASHCHAT_MODEL_CONFIG="$(flashchat_get MODEL_CONFIG)"
    export FLASHCHAT_SESSIONS_DIR="$(flashchat_get_sessions_dir)"
    export FLASHCHAT_SYSTEM_PROMPT="$(flashchat_get_system_prompt_file)"
    
    ensure_binaries
    
    case "$target" in
        run)
            echo "Running: single expert forward pass..."
            make -C "$SCRIPT_DIR" run
            ;;
        verify)
            echo "Running: Metal vs CPU verification..."
            make -C "$SCRIPT_DIR" verify
            ;;
        bench)
            echo "Running: single expert benchmark (10 iterations)..."
            make -C "$SCRIPT_DIR" bench
            ;;
        moe)
            echo "Running: MoE forward (K experts, single layer)..."
            make -C "$SCRIPT_DIR" moe
            ;;
        moebench)
            echo "Running: MoE benchmark (10 iterations)..."
            make -C "$SCRIPT_DIR" moebench
            ;;
        full)
            echo "Running: Full model forward (K=4)..."
            make -C "$SCRIPT_DIR" full
            ;;
        fullbench)
            echo "Running: Full benchmark (3 iterations)..."
            make -C "$SCRIPT_DIR" fullbench
            ;;
        *)
            echo "Unknown benchmark: $target"
            echo "Run 'flashchat benchmark' to see available targets."
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            --config)
                CONFIG_FILE="$2"
                FLASHCHAT_CONFIG_FILE_OVERRIDE="$2"
                export FLASHCHAT_CONFIG_FILE_OVERRIDE
                shift 2
                ;;
            --model)
                export FLASHCHAT_MODEL="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done
    
    if [ $# -eq 0 ]; then
        interactive_menu
        return
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h)
            show_help
            ;;
        status)
            cmd_status "$@"
            ;;
        sessions)
            cmd_sessions "$@"
            ;;
        models)
            cmd_models "$@"
            ;;
        manage)
            cmd_manage "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        chat)
            ensure_setup
            cmd_chat "$@"
            ;;
        serve)
            cmd_serve "$@"
            ;;
        prompt)
            ensure_setup
            cmd_prompt "$@"
            ;;
        opencode)
            ensure_setup
            cmd_opencode "$@"
            ;;
        benchmark)
            cmd_benchmark "$@"
            ;;
        *)
            error "Unknown command: $command"
            ;;
    esac
}

main "$@"
