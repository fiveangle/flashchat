#!/bin/bash
# flashchat — Flashchat Unified Management CLI
#
# Usage:
#   flashchat [command] [options]
#
# Commands:
#   chat              Start chat (auto-sets up if missing)
#   chat --resume ID  Resume session
#   opencode          Launch OpenCode against the local Flashchat server
#   serve             Start API server (auto-sets up if missing)
#   serve --stop      Stop running server
#   serve --stop --external  Stop external Flashchat server on configured port
#   prompt "..."      Single prompt (auto-sets up if missing)
#   config            Edit/show configuration
#   models            List supported models and setup status
#   manage            Manage local/offloaded model storage
#   status            Show system status
#   sessions          List sessions
#   help              Show this help
#
# Options:
#   --config FILE     Use specific config
#   -v, --verbose    Verbose output
#   -q, --quiet      Quiet mode
#
# Configuration:
#   Config is loaded from (priority highest to lowest):
#     1. --config FILE (explicit override)
#     2. ~/.config/flashchat/config (user)
#     3. Environment variables (FLASHCHAT_*)
#     4. Registry/default values

set -e
set +m  # Disable job control messages

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib/config.sh"

# Global flags
VERBOSE=0
QUIET=0
CONFIG_FILE=""

# -----------------------------------------------------------------------------
# Helper functions
# -----------------------------------------------------------------------------

log() {
    [ "$QUIET" -eq 0 ] && echo "$@"
}

logv() {
    [ "$VERBOSE" -eq 1 ] && echo "[DEBUG] $@"
}

error() {
    echo "ERROR: $@" >&2
    exit 1
}

# -----------------------------------------------------------------------------
# Parse global options
# -----------------------------------------------------------------------------
parse_global_opts() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            --config)
                CONFIG_FILE="$2"
                FLASHCHAT_CONFIG_FILE_OVERRIDE="$2"
                export FLASHCHAT_CONFIG_FILE_OVERRIDE
                shift 2
                ;;
            --model)
                export FLASHCHAT_MODEL="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Show help
# -----------------------------------------------------------------------------
show_help() {
    cat << EOF
flashchat — Flashchat Unified Management CLI

Usage:
  flashchat [command] [options]

Commands:
  chat              Start chat interface
  chat --resume ID  Resume existing chat session
  opencode          Launch OpenCode with the local Flashchat server
  serve             Start API server
  serve --stop      Stop running API server
  serve --stop --external  Stop external Flashchat server on configured port
  serve --stop --force  Force-stop running API server
  prompt "..."      Run single prompt and exit
  benchmark         Run benchmarks (run, verify, bench, moe, moebench, full, fullbench)
  config            Edit configuration settings
  models            List supported models and local setup status
  manage            Manage local/offloaded model storage
  status            Show system status
  sessions          List chat sessions
  help              Show this help

Options:
  --config FILE     Use specific config file
  -v, --verbose    Verbose output
  -q, --quiet      Quiet mode

Configuration:
  Config is loaded from (priority highest to lowest):
    1. --config FILE (explicit override)
    2. ~/.config/flashchat/config (user)
    3. Environment variables (FLASHCHAT_*)
    4. Registry/default values

Environment variables:
  FLASHCHAT_MODEL           Model ID (default: qwen3.6-35B-A3B)
  FLASHCHAT_MODEL_PATH      Override model path
  FLASHCHAT_MODEL_CONFIG    Override bundled model registry path
  FLASHCHAT_OFFLOAD_DIR     Unified model offload directory
  FLASHCHAT_SERVER_PORT    Server port
  FLASHCHAT_SERVER_HOST    Server host clients connect to
  FLASHCHAT_WEIGHTS_DIR    Path to extracted weights
  FLASHCHAT_EXPERTS_DIR   Path to expert weights

For more info, see: https://github.com/fiveangle/flash-moe
EOF
}

print_opencode_config_snippet() {
    local server_port="$1"
    local server_host="$2"
    local model_repo
    model_repo="$(flashchat_get MODEL_REPO)"
    cat << EOF
Add this provider to ~/.config/opencode/opencode.jsonc:

{
  "\$schema": "https://opencode.ai/config.json",
  "provider": {
    "flashchat": {
      "name": "flashchat",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "${model_repo}": {
          "name": "Qwen3.5-397B-A17B-4bit",
          "tools": true,
          "limit": {
            "context": 220000,
            "output": 16000
          }
        }
      },
      "options": {
        "baseURL": "http://${server_host}:${server_port}/v1"
      }
    }
  }
}
EOF
}

check_opencode_config() {
    local server_port="$1"
    local server_host="$2"
    local config_path="${HOME}/.config/opencode/opencode.jsonc"

    if [ ! -f "$config_path" ]; then
        echo "OpenCode config not found: $config_path"
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        return 1
    fi

    if ! rg -q '@ai-sdk/openai-compatible' "$config_path"; then
        echo "OpenCode config exists but does not appear to define an OpenAI-compatible provider."
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        return 1
    fi

    if ! rg -q "${server_host}:${server_port}/v1" "$config_path"; then
        echo "OpenCode config does not currently point at http://${server_host}:${server_port}/v1"
        echo "Continuing, but if the harness connects to the wrong backend, update your config to:"
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        echo ""
    fi

    return 0
}

flashchat_server_connect_host() {
    local host
    host="$(flashchat_get SERVER_HOST)"
    case "$host" in
        ""|"0.0.0.0"|"::")
            echo "127.0.0.1"
            ;;
        *)
            echo "$host"
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Command: status
# -----------------------------------------------------------------------------
cmd_status() {
    flashchat_load_config
    
    echo "=== Flashchat Show Status ==="
    echo "Server: http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)"
    
    # Check if server is running
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            echo "Server status: Running (PID: $pid)"
        else
            echo "Server status: Not running (stale PID file)"
        fi
    else
        echo "Server status: Not running"
    fi

    echo "API Endpoints:"
    echo "    POST /v1/chat/completions  (chat)"
    echo "    GET  /v1/models            (list models)"
    echo "    GET  /health               (health check)"
    echo ""
    echo "Model: $(flashchat_get MODEL) ($(flashchat_get MODEL_REPO))"
    echo "Context window size: $(flashchat_get MAX_TOKENS) tokens"
    echo "Temperature: $(flashchat_get TEMPERATURE) (randomness - higher = more creative)"
    echo "Top-p: $(flashchat_get TOP_P) (nucleus sampling - controls diversity)"
    echo "Show thinking: $(flashchat_get SHOW_THINKING)"
    echo "Color output: $(flashchat_get COLOR_OUTPUT)"
    echo "User state: $(flashchat_get CONFIG_DIR)"
    echo "Offload dir: $(flashchat_get OFFLOAD_DIR)"
}

# -----------------------------------------------------------------------------
# Command: sessions
# -----------------------------------------------------------------------------
cmd_sessions() {
    local delete_id=""
    local list=1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --delete)
                delete_id="$2"
                list=0
                shift 2
                ;;
            -d)
                delete_id="$2"
                list=0
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    local sessions_dir
    sessions_dir=$(flashchat_get_sessions_dir)
    
    # Handle delete
    if [ -n "$delete_id" ]; then
        local session_file="$sessions_dir/${delete_id}.jsonl"
        if [ -f "$session_file" ]; then
            rm -f "$session_file"
            echo "Deleted session: $delete_id"
        else
            error "Session not found: $delete_id"
        fi
        return
    fi
    
    echo "=== Chat Sessions ==="
    echo ""
    
    if [ ! -d "$sessions_dir" ]; then
        echo "(no sessions)"
        return
    fi
    
    local count=0
    for f in "$sessions_dir"/*.jsonl; do
        [ -f "$f" ] || continue
        local session_id
        session_id=$(basename "$f" .jsonl)
        local lines
        lines=$(wc -l < "$f")
        local last_modified
        last_modified=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d' ' -f1)
        echo "  $session_id ($lines turns, $last_modified)"
        count=$((count + 1))
    done
    
    if [ $count -eq 0 ]; then
        echo "(no sessions)"
    else
        echo "To resume a session: flashchat chat --resume <session_id>"
        echo "To delete a session: flashchat sessions --delete <session_id>"
    fi
}

# -----------------------------------------------------------------------------
# Command: config
# -----------------------------------------------------------------------------
cmd_config() {
    local reset_mode=""
    local full_reset=0
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reset)
                reset_mode="environment"
                shift
                ;;
            --full-reset)
                reset_mode="environment"
                full_reset=1
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    local config_file
    config_file=$(flashchat_get CONFIG_FILE)
    
    # Handle reset modes
    if [ "$reset_mode" = "environment" ]; then
        if [ $full_reset -eq 1 ]; then
            echo "=== Full Reset ==="
            echo ""
            echo "This will delete ALL data including:"
            echo "  - Configuration"
            echo "  - All chat sessions"
            echo "  - All settings"
            read -p "Are you sure? [y/N] " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                rm -f "$config_file"
                rm -rf "$(flashchat_get_sessions_dir)"
                rm -f "$(flashchat_get_history_file)" "$(flashchat_get_system_prompt_file)"
                echo "Full reset complete. All data deleted."
            else
                echo "Cancelled."
            fi
        else
            echo "=== Reset Environment ==="
            echo ""
            echo "This will re-run the setup wizard and configuration."
            echo "Your chat sessions will be preserved."
            read -p "Continue? [Y/n] " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
                prompt_config_options
                
                echo "Setup Components"
                echo "================"
                ensure_setup 1
                
                echo "Configuration saved."
            else
                echo "Cancelled."
            fi
        fi
        return
    fi
    
    if [ ! -f "$config_file" ]; then
        echo "No config file found. Using defaults..."
        flashchat_create_default_config
        flashchat_load_config
        config_file=$(flashchat_get CONFIG_FILE)
    fi
    
    echo "=== Flashchat Configuration ==="
    echo ""
    echo "Model: $(flashchat_get MODEL)"
    echo "Repository: $(flashchat_get MODEL_REPO)"
    echo "Context window size: $(flashchat_get MAX_TOKENS) tokens | Temperature: $(flashchat_get TEMPERATURE) (creativity) | Top-p: $(flashchat_get TOP_P) (nucleus)"
    echo "Server: http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)"
    echo "Show thinking: $(flashchat_get SHOW_THINKING) | Server debug: $(flashchat_get SERVER_DEBUG) | HTTP log: $(flashchat_get SERVER_HTTP_LOG) | Color: $(flashchat_get COLOR_OUTPUT)"
    echo "Server log path: $(flashchat_get SERVER_LOG_PATH)"
    echo "Offload dir: $(flashchat_get OFFLOAD_DIR)"
    echo ""
    echo "File: $config_file"
    echo ""
    
    cmd_config_interactive
}

# -----------------------------------------------------------------------------
# Command: config (interactive menu version)
# -----------------------------------------------------------------------------
cmd_config_interactive() {
    flashchat_load_config
    
    echo ""
    echo "=== Configuration Settings ==="
    echo "  -Model: $(flashchat_get MODEL)"
    echo "  -Repository: $(flashchat_get MODEL_REPO)"
    echo "  -Context window size: $(flashchat_get MAX_TOKENS) tokens"
    echo "  -Temperature (0.0-2.0): $(flashchat_get TEMPERATURE) (randomness - higher = more creative)"
    echo "  -Top-p (0.0-1.0): $(flashchat_get TOP_P) (nucleus sampling - controls output diversity)"
    echo "  -Server API publishing port: $(flashchat_get SERVER_PORT)"
    echo "  -Chat client API host IP: $(flashchat_get SERVER_HOST)"
    echo "  -Server log path (file or directory): $(flashchat_get SERVER_LOG_PATH)"
    echo "  -Model offload directory: $(flashchat_get OFFLOAD_DIR)"
    echo "  -Server debug logging artifacts (0/1): $(flashchat_get SERVER_DEBUG)"
    echo "  -Server HTTP traffic log (0/1): $(flashchat_get SERVER_HTTP_LOG)"
    echo "  -Show thinking tokens (0/1): $(flashchat_get SHOW_THINKING)"
    echo "  -Color output (0/1): $(flashchat_get COLOR_OUTPUT)"
    unset REPLY
    read -p "Start configuration wizard? [Y/n]: " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        prompt_config_interactive
    else
        echo "Cancelled."
    fi
}

model_has_hf_files() {
    local model_path="$1"
    for f in "$model_path"/model-*.safetensors "$model_path"/model.safetensors; do
        [ -f "$f" ] && return 0
    done
    [ -f "$model_path/config.json" ]
}

model_status_value() {
    if "$@"; then
        echo "yes"
    else
        echo "no"
    fi
}

model_artifact_status() {
    local model_id="$1"
    local model_path
    model_path=$(flashchat_model_path_for_id "$model_id")
    local layers
    layers=$(flashchat_model_layers "$model_id")
    local last_layer=$((layers - 1))
    local runtime_dir="${model_path}/flashchat"
    local experts_dir="${runtime_dir}/packed_experts"

    local downloaded weights vocab index experts
    downloaded=$(model_status_value model_has_hf_files "$model_path")
    weights=$(model_status_value test -f "${runtime_dir}/model_weights.bin" -a -f "${runtime_dir}/model_weights.json")
    vocab=$(model_status_value test -f "${runtime_dir}/vocab.bin")
    index=$(model_status_value test -f "${runtime_dir}/expert_index.json")
    experts=$(model_status_value test -f "${experts_dir}/layer_$(printf "%02d" "$last_layer").bin")

    echo "downloaded: $downloaded | weights: $weights | vocab: $vocab | expert index: $index | experts: $experts"
}

print_model_status_list() {
    local current_model
    current_model="$(flashchat_get MODEL)"
    local i=0
    local model_id name repo marker status

    while IFS=$'\t' read -r model_id name repo; do
        [ -n "$model_id" ] || continue
        i=$((i + 1))
        marker=" "
        [ "$model_id" = "$current_model" ] && marker="*"
        status=$(model_artifact_status "$model_id")
        printf "  [%d]%s %s\n" "$i" "$marker" "$name"
        printf "      ID: %s\n" "$model_id"
        printf "      Repo: %s\n" "$repo"
        printf "      %s\n" "$status"
    done < <(flashchat_list_models)
}

select_model_from_registry() {
    local default_model="$1"
    local model_ids=()
    local model_id name repo
    local i=0

    echo "Available models:" >&2
    echo "" >&2
    print_model_status_list >&2
    echo "" >&2
    while IFS=$'\t' read -r model_id name repo; do
        [ -n "$model_id" ] || continue
        model_ids+=("$model_id")
    done < <(flashchat_list_models)

    if [ ${#model_ids[@]} -eq 0 ]; then
        echo "No model registry entries found. Using $default_model." >&2
        echo "$default_model"
        return
    fi

    while true; do
        printf "Select model number or ID [%s]: " "$default_model" >&2
        read -r REPLY
        echo "" >&2
        if [ -z "$REPLY" ]; then
            echo "$default_model"
            return
        fi
        if [[ "$REPLY" =~ ^[0-9]+$ ]]; then
            i=$((REPLY - 1))
            if [ "$i" -ge 0 ] && [ "$i" -lt ${#model_ids[@]} ]; then
                echo "${model_ids[$i]}"
                return
            fi
        elif flashchat_model_exists "$REPLY"; then
            echo "$REPLY"
            return
        fi
        echo "Please choose one of the listed models." >&2
    done
}

cmd_models() {
    flashchat_load_config
    echo "=== Flashchat Models ==="
    echo ""
    print_model_status_list
    echo ""
    echo "* Current model"
}

hf_repo_dir_name() {
    local repo="$1"
    printf "models--%s\n" "${repo//\//--}"
}

flashchat_hf_cache_dir() {
    printf "%s/.cache/huggingface/hub\n" "$HOME"
}

model_local_repo_dir() {
    local model_id="$1"
    local repo
    repo=$(flashchat_model_repo "$model_id")
    [ -n "$repo" ] || return 1
    printf "%s/%s\n" "$(flashchat_hf_cache_dir)" "$(hf_repo_dir_name "$repo")"
}

model_offloaded_repo_dir() {
    local model_id="$1"
    local offload_dir
    local repo
    offload_dir="$(flashchat_get OFFLOAD_DIR)"
    repo=$(flashchat_model_repo "$model_id")
    [ -n "$offload_dir" ] || return 1
    [ -n "$repo" ] || return 1
    printf "%s/%s\n" "$offload_dir" "$(hf_repo_dir_name "$repo")"
}

latest_snapshot_in_repo() {
    local repo_dir="$1"
    local snapshot_dir="${repo_dir}/snapshots"
    [ -d "$snapshot_dir" ] || return 1
    local latest
    latest=$(ls -1 "$snapshot_dir" 2>/dev/null | sort | tail -1)
    [ -n "$latest" ] || return 1
    printf "%s/%s\n" "$snapshot_dir" "$latest"
}

dir_size_human() {
    local path="$1"
    if [ -e "$path" ]; then
        du -sh "$path" 2>/dev/null | awk '{print $1}'
    fi
}

model_runtime_ready_for_snapshot() {
    local model_id="$1"
    local snapshot="$2"
    local runtime_dir="${snapshot}/flashchat"
    local experts_dir="${runtime_dir}/packed_experts"
    local layers
    local i

    [ -d "$runtime_dir" ] || return 1
    [ -f "${runtime_dir}/model_weights.bin" ] || return 1
    [ -f "${runtime_dir}/model_weights.json" ] || return 1
    [ -f "${runtime_dir}/vocab.bin" ] || return 1
    [ -f "${runtime_dir}/expert_index.json" ] || return 1

    layers=$(flashchat_model_layers "$model_id")
    i=0
    while [ "$i" -lt "$layers" ]; do
        [ -f "${experts_dir}/layer_$(printf "%02d" "$i").bin" ] || return 1
        i=$((i + 1))
    done
}

model_runtime_status_for_repo() {
    local model_id="$1"
    local repo_dir="$2"
    local snapshot
    snapshot=$(latest_snapshot_in_repo "$repo_dir" 2>/dev/null || true)
    if [ -n "$snapshot" ] && model_runtime_ready_for_snapshot "$model_id" "$snapshot"; then
        echo "ready"
    else
        echo "not ready"
    fi
}

model_original_blob_size_for_repo() {
    local repo_dir="$1"
    local snapshot
    snapshot=$(latest_snapshot_in_repo "$repo_dir" 2>/dev/null || true)
    if [ -n "$snapshot" ]; then
        get_model_blobs_size "$snapshot"
    fi
}

confirm_exact_model_id() {
    local model_id="$1"
    local prompt="${2:-Type the exact model ID to continue}"
    echo "$prompt"
    printf "Model ID: "
    read -r REPLY
    if [ "$REPLY" = "$model_id" ]; then
        return 0
    fi
    echo "Cancelled. Confirmation did not match '$model_id'."
    return 1
}

ensure_offload_dir() {
    local offload_dir
    offload_dir="$(flashchat_get OFFLOAD_DIR)"
    if [ -z "$offload_dir" ]; then
        echo "No OFFLOAD_DIR is configured. Set it with './flashchat config' before using offload storage."
        return 1
    fi
    if [[ "$offload_dir" != /* ]]; then
        echo "OFFLOAD_DIR must be an absolute path: $offload_dir"
        return 1
    fi
    if ! mkdir -p "$offload_dir"; then
        echo "Unable to create OFFLOAD_DIR: $offload_dir"
        return 1
    fi
    if [ ! -w "$offload_dir" ]; then
        echo "OFFLOAD_DIR is not writable: $offload_dir"
        return 1
    fi
}

current_model_server_running() {
    local model_id="$1"
    [ "$model_id" = "$(flashchat_get MODEL)" ] || return 1
    if is_server_running; then
        return 0
    fi
    is_port_listening "$(flashchat_get SERVER_PORT)"
}

print_manage_model_status_list() {
    local current_model
    current_model="$(flashchat_get MODEL)"
    local offload_dir
    offload_dir="$(flashchat_get OFFLOAD_DIR)"
    local i=0
    local model_id name repo marker local_repo offloaded_repo
    local local_state offloaded_state runtime_state offloaded_runtime blobs_size local_size offloaded_size

    if [ -n "$offload_dir" ]; then
        echo "Offload directory: $offload_dir"
    else
        echo "Offload directory: (not configured)"
    fi
    echo ""

    while IFS=$'\t' read -r model_id name repo; do
        [ -n "$model_id" ] || continue
        i=$((i + 1))
        marker=" "
        [ "$model_id" = "$current_model" ] && marker="*"
        local_repo=$(model_local_repo_dir "$model_id")
        offloaded_repo=$(model_offloaded_repo_dir "$model_id" 2>/dev/null || true)

        local_state="no"
        runtime_state="not ready"
        blobs_size=""
        local_size=""
        if [ -d "$local_repo" ]; then
            local_state="yes"
            local_size=$(dir_size_human "$local_repo")
            runtime_state=$(model_runtime_status_for_repo "$model_id" "$local_repo")
            blobs_size=$(model_original_blob_size_for_repo "$local_repo")
        fi

        offloaded_state="no"
        offloaded_runtime="not ready"
        offloaded_size=""
        if [ -n "$offloaded_repo" ] && [ -d "$offloaded_repo" ]; then
            offloaded_state="yes"
            offloaded_size=$(dir_size_human "$offloaded_repo")
            offloaded_runtime=$(model_runtime_status_for_repo "$model_id" "$offloaded_repo")
        fi

        printf "  [%d]%s %s\n" "$i" "$marker" "$name"
        printf "      ID: %s\n" "$model_id"
        printf "      Repo: %s\n" "$repo"
        printf "      Local: %s | runtime: %s | original blobs: %s | total: %s\n" "$local_state" "$runtime_state" "${blobs_size:-absent}" "${local_size:-absent}"
        printf "      Offloaded: %s | runtime: %s | total: %s\n" "$offloaded_state" "$offloaded_runtime" "${offloaded_size:-absent}"
    done < <(flashchat_list_models)
    echo ""
    echo "* Current model"
}

select_manage_model() {
    local model_ids=()
    local model_id name repo
    local i=0

    while IFS=$'\t' read -r model_id name repo; do
        [ -n "$model_id" ] || continue
        model_ids+=("$model_id")
    done < <(flashchat_list_models)

    if [ ${#model_ids[@]} -eq 0 ]; then
        echo "No model registry entries found." >&2
        return 1
    fi

    while true; do
        printf "Select model number or ID, [Q]uit: " >&2
        read -r REPLY
        if [[ "$REPLY" =~ ^[Qq]$ ]] || [ -z "$REPLY" ]; then
            return 1
        fi
        if [[ "$REPLY" =~ ^[0-9]+$ ]]; then
            i=$((REPLY - 1))
            if [ "$i" -ge 0 ] && [ "$i" -lt ${#model_ids[@]} ]; then
                echo "${model_ids[$i]}"
                return 0
            fi
        elif flashchat_model_exists "$REPLY"; then
            echo "$REPLY"
            return 0
        fi
        echo "Please choose one of the listed models." >&2
    done
}

manage_remove_original_blobs() {
    local model_id="$1"
    local local_repo snapshot blobs_size
    local_repo=$(model_local_repo_dir "$model_id")
    if [ ! -d "$local_repo" ]; then
        echo "Local model is not present."
        return 1
    fi
    snapshot=$(latest_snapshot_in_repo "$local_repo" 2>/dev/null || true)
    if [ -z "$snapshot" ]; then
        echo "Local model has no snapshot directory."
        return 1
    fi
    if ! model_runtime_ready_for_snapshot "$model_id" "$snapshot"; then
        echo "Original blobs can only be removed after the runtime artifacts are complete."
        echo "Expected model_weights.bin, model_weights.json, vocab.bin, expert_index.json, and all packed expert layers."
        return 1
    fi
    blobs_size=$(get_model_blobs_size "$snapshot")
    if [ -z "$blobs_size" ]; then
        echo "No original safetensors blobs found."
        return 0
    fi
    echo "This will remove $blobs_size of original safetensors blobs from the local model."
    confirm_exact_model_id "$model_id" "Type the exact model ID to remove original blobs:" || return 1
    if delete_model_blobs "$snapshot"; then
        echo "Original blobs removed."
    else
        echo "No original blobs were removed."
    fi
}

manage_delete_local_model() {
    local model_id="$1"
    local local_repo
    local_repo=$(model_local_repo_dir "$model_id")
    if [ ! -d "$local_repo" ]; then
        echo "Local model is not present."
        return 0
    fi
    if current_model_server_running "$model_id"; then
        echo "Refusing to delete the configured model while the Flashchat server is running."
        return 1
    fi
    echo "This will delete the entire local HuggingFace cache repo:"
    echo "$local_repo"
    confirm_exact_model_id "$model_id" "Type the exact model ID to delete the local model:" || return 1
    if ! rm -rf "$local_repo"; then
        echo "Unable to delete local model: $local_repo"
        return 1
    fi
    echo "Local model deleted."
}

manage_offload_model() {
    local model_id="$1"
    local local_repo offloaded_repo
    ensure_offload_dir || return 1
    local_repo=$(model_local_repo_dir "$model_id")
    offloaded_repo=$(model_offloaded_repo_dir "$model_id")
    if [ ! -d "$local_repo" ]; then
        echo "Local model is not present."
        return 1
    fi
    if [ -e "$offloaded_repo" ]; then
        echo "Refusing to overwrite existing offloaded model:"
        echo "$offloaded_repo"
        return 1
    fi
    if current_model_server_running "$model_id"; then
        echo "Refusing to offload the configured model while the Flashchat server is running."
        return 1
    fi
    echo "This will move the entire local model repo to:"
    echo "$offloaded_repo"
    confirm_exact_model_id "$model_id" "Type the exact model ID to offload this model:" || return 1
    if ! mkdir -p "$(dirname "$offloaded_repo")"; then
        echo "Unable to create offload destination parent."
        return 1
    fi
    if ! mv "$local_repo" "$offloaded_repo"; then
        echo "Unable to offload model."
        return 1
    fi
    echo "Model offloaded."
}

manage_full_reload_model() {
    local model_id="$1"
    local local_repo offloaded_repo
    ensure_offload_dir || return 1
    local_repo=$(model_local_repo_dir "$model_id")
    offloaded_repo=$(model_offloaded_repo_dir "$model_id")
    if [ ! -d "$offloaded_repo" ]; then
        echo "Offloaded model is not present."
        return 1
    fi
    if [ -e "$local_repo" ]; then
        echo "Refusing to overwrite existing local model:"
        echo "$local_repo"
        return 1
    fi
    echo "This will move the entire offloaded model repo back to local HuggingFace cache:"
    echo "$local_repo"
    confirm_exact_model_id "$model_id" "Type the exact model ID to fully reload this model:" || return 1
    if ! mkdir -p "$(dirname "$local_repo")"; then
        echo "Unable to create local HuggingFace cache parent."
        return 1
    fi
    if ! mv "$offloaded_repo" "$local_repo"; then
        echo "Unable to reload model."
        return 1
    fi
    echo "Model fully reloaded."
}

manage_restore_runtime_only() {
    local model_id="$1"
    local local_repo offloaded_repo source_snapshot source_runtime local_snapshot local_runtime
    ensure_offload_dir || return 1
    local_repo=$(model_local_repo_dir "$model_id")
    offloaded_repo=$(model_offloaded_repo_dir "$model_id")
    if [ ! -d "$offloaded_repo" ]; then
        echo "Offloaded model is not present."
        return 1
    fi
    source_snapshot=$(latest_snapshot_in_repo "$offloaded_repo" 2>/dev/null || true)
    if [ -z "$source_snapshot" ]; then
        echo "Offloaded model has no snapshot directory."
        return 1
    fi
    if ! model_runtime_ready_for_snapshot "$model_id" "$source_snapshot"; then
        echo "Offloaded model does not have complete runtime artifacts."
        return 1
    fi
    source_runtime="${source_snapshot}/flashchat"
    local_snapshot="${local_repo}/snapshots/$(basename "$source_snapshot")"
    local_runtime="${local_snapshot}/flashchat"

    if [ -e "$local_runtime" ]; then
        echo "Local runtime artifacts already exist:"
        echo "$local_runtime"
        confirm_exact_model_id "$model_id" "Type the exact model ID to overwrite the local runtime artifacts:" || return 1
        if ! rm -rf "$local_runtime"; then
            echo "Unable to remove existing local runtime artifacts."
            return 1
        fi
    fi

    if ! mkdir -p "$local_snapshot"; then
        echo "Unable to create local snapshot directory."
        return 1
    fi
    if ! cp -R "$source_runtime" "$local_snapshot/"; then
        echo "Unable to restore runtime artifacts."
        return 1
    fi
    echo "Runtime artifacts restored without copying original safetensors blobs."
}

manage_model_menu() {
    local model_id="$1"
    local name
    name=$(flashchat_model_name "$model_id")
    while true; do
        echo ""
        echo "=== Manage ${name:-$model_id} ==="
        echo "Model ID: $model_id"
        echo ""
        echo "  [1] Remove original blobs"
        echo "  [2] Delete local model"
        echo "  [3] Offload local model"
        echo "  [4] Full reload from offload"
        echo "  [5] Restore runtime only from offload"
        echo "  [Q] Back"
        printf "> "
        read -r REPLY
        case "$REPLY" in
            1) manage_remove_original_blobs "$model_id" || true ;;
            2) manage_delete_local_model "$model_id" || true ;;
            3) manage_offload_model "$model_id" || true ;;
            4) manage_full_reload_model "$model_id" || true ;;
            5) manage_restore_runtime_only "$model_id" || true ;;
            q|Q|"") return ;;
            *) echo "Please choose one of the listed actions." ;;
        esac
    done
}

cmd_manage() {
    local list_only=0
    local force_interactive=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --list|-l)
                list_only=1
                shift
                ;;
            --interactive)
                force_interactive=1
                shift
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done

    flashchat_load_config
    echo "=== Flashchat Manage Models ==="
    echo ""
    print_manage_model_status_list

    if [ "$list_only" -eq 1 ] || { [ "$force_interactive" -eq 0 ] && [ ! -t 0 ]; }; then
        return
    fi

    local model_id
    if model_id=$(select_manage_model); then
        manage_model_menu "$model_id"
    fi
}

