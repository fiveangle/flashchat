    echo "MODEL=\"$selected_model\"" >> /tmp/flashchat_new_config
    echo ""
    
    # Max Tokens
    local default_tokens
    default_tokens=$(flashchat_get MAX_TOKENS)
    printf "Context window limit [%s]: " "$default_tokens"
    read -r REPLY
    echo ""
    echo "MAX_TOKENS=\"${REPLY:-$default_tokens}\"" >> /tmp/flashchat_new_config
    
    # Temperature
    local default_temp
    default_temp=$(flashchat_get TEMPERATURE)
    printf "Temperature (0.0-2.0) [randomness - higher=creative, lower=focused] [%s]: " "$default_temp"
    read -r REPLY
    echo ""
    echo "TEMPERATURE=\"${REPLY:-$default_temp}\"" >> /tmp/flashchat_new_config
    
    # Top P
    local default_top_p
    default_top_p=$(flashchat_get TOP_P)
    printf "Top-p (0.0-1.0) [nucleus sampling - lower=focused, higher=diverse] [%s]: " "$default_top_p"
    read -r REPLY
    echo ""
    echo "TOP_P=\"${REPLY:-$default_top_p}\"" >> /tmp/flashchat_new_config
    
    # Server Port
    local default_port
    default_port=$(flashchat_get SERVER_PORT)
    printf "Server port [%s]: " "$default_port"
    read -r REPLY
    echo ""
    echo "SERVER_PORT=\"${REPLY:-$default_port}\"" >> /tmp/flashchat_new_config
    
    # Server Host
    local default_host
    default_host=$(flashchat_get SERVER_HOST)
    printf "Server host [%s]: " "$default_host"
    read -r REPLY
    echo ""
    echo "SERVER_HOST=\"${REPLY:-$default_host}\"" >> /tmp/flashchat_new_config

    # Server Log Path
    local default_log_path
    default_log_path=$(flashchat_get SERVER_LOG_PATH)
    printf "Server log path (file or directory) [%s]: " "$default_log_path"
    read -r REPLY
    echo ""
    echo "SERVER_LOG_PATH=\"${REPLY:-$default_log_path}\"" >> /tmp/flashchat_new_config

    # Model Offload Directory
    local default_offload_dir
    default_offload_dir=$(flashchat_get OFFLOAD_DIR)
    printf "Model offload directory (absolute path, '-' = disabled) [%s]: " "${default_offload_dir:-disabled}"
    read -r REPLY
    echo ""
    if [ "$REPLY" = "-" ]; then
        echo "OFFLOAD_DIR=\"\"" >> /tmp/flashchat_new_config
    elif [ -z "$REPLY" ] && [ -z "$default_offload_dir" ]; then
        echo "OFFLOAD_DIR=\"\"" >> /tmp/flashchat_new_config
    else
        echo "OFFLOAD_DIR=\"${REPLY:-$default_offload_dir}\"" >> /tmp/flashchat_new_config
    fi

    # Server Debug
    local default_debug
    default_debug=$(flashchat_get SERVER_DEBUG)
    printf "Server debug logging artifacts (0/1) [%s]: " "$default_debug"
    read -r REPLY
    echo ""
    echo "SERVER_DEBUG=\"${REPLY:-$default_debug}\"" >> /tmp/flashchat_new_config

    # Server HTTP Log
    local default_http_log
    default_http_log=$(flashchat_get SERVER_HTTP_LOG)
    printf "Server HTTP traffic log (0/1) [%s]: " "$default_http_log"
    read -r REPLY
    echo ""
    echo "SERVER_HTTP_LOG=\"${REPLY:-$default_http_log}\"" >> /tmp/flashchat_new_config

    # Show Thinking
    local default_think
    default_think=$(flashchat_get SHOW_THINKING)
    printf "Show thinking tokens (0/1) [%s]: " "$default_think"
    read -r REPLY
    echo ""
    echo "SHOW_THINKING=\"${REPLY:-$default_think}\"" >> /tmp/flashchat_new_config
    
    # Color Output
    local default_color
    default_color=$(flashchat_get COLOR_OUTPUT)
    printf "Color output (0/1) [%s]: " "$default_color"
    read -r REPLY
    echo ""
    echo "COLOR_OUTPUT=\"${REPLY:-$default_color}\"" >> /tmp/flashchat_new_config
    
    # Save config only if changed
    local old_config
    old_config=$(cat "$(flashchat_get CONFIG_FILE)")
    local new_config
    new_config=$(cat /tmp/flashchat_new_config)
    rm -f /tmp/flashchat_new_config
    
    if [ "$old_config" = "$new_config" ]; then
        echo "No changes made."
    else
        echo "$new_config" > "$(flashchat_get CONFIG_FILE)"
        echo "Configuration updated."
    fi
}

