print_opencode_config_snippet() {
    local server_port="$1"
    local server_host="$2"
    local model_repo
    model_repo="$(flashchat_get MODEL_REPO)"
    cat << EOF
Add this provider to ~/.config/opencode/opencode.jsonc:

{
  "\$schema": "https://opencode.ai/config.json",
  "provider": {
    "flashchat": {
      "name": "flashchat",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "${model_repo}": {
          "name": "Qwen3.5-397B-A17B-4bit",
          "tools": true,
          "limit": {
            "context": 220000,
            "output": 16000
          }
        }
      },
      "options": {
        "baseURL": "http://${server_host}:${server_port}/v1"
      }
    }
  }
}
EOF
}

check_opencode_config() {
    local server_port="$1"
    local server_host="$2"
    local config_path="${HOME}/.config/opencode/opencode.jsonc"

    if [ ! -f "$config_path" ]; then
        echo "OpenCode config not found: $config_path"
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        return 1
    fi

    if ! rg -q '@ai-sdk/openai-compatible' "$config_path"; then
        echo "OpenCode config exists but does not appear to define an OpenAI-compatible provider."
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        return 1
    fi

    if ! rg -q "${server_host}:${server_port}/v1" "$config_path"; then
        echo "OpenCode config does not currently point at http://${server_host}:${server_port}/v1"
        echo "Continuing, but if the harness connects to the wrong backend, update your config to:"
        echo ""
        print_opencode_config_snippet "$server_port" "$server_host"
        echo ""
    fi

    return 0
}

flashchat_server_connect_host() {
    local host
    host="$(flashchat_get SERVER_HOST)"
    case "$host" in
        ""|"0.0.0.0"|"::")
            echo "127.0.0.1"
            ;;
        *)
            echo "$host"
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Command: status
# -----------------------------------------------------------------------------
cmd_status() {
    flashchat_load_config
    
    echo "=== Flashchat Show Status ==="
    echo "Server: http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)"
    
    # Check if server is running
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            if server_signature_matches_config "$server_port"; then
                echo "Server status: Running (PID: $pid)"
            else
                echo "Server status: Running with stale runtime settings (PID: $pid)"
            fi
        else
            echo "Server status: Not running (stale PID file)"
        fi
    else
        echo "Server status: Not running"
    fi

    echo "API Endpoints:"
    echo "    POST /v1/chat/completions  (chat)"
    echo "    GET  /v1/models            (list models)"
    echo "    GET  /health               (health check)"
    echo ""
    echo "Model: $(flashchat_get MODEL) ($(flashchat_get MODEL_REPO))"
    echo "Quantization: $(current_quantization_label)"
    echo "Sampling profile: $(flashchat_get SAMPLING_PROFILE)"
    echo "Max response length: $(flashchat_get MAX_TOKENS) tokens"
    echo "Reasoning: $(flashchat_get REASONING)"
    echo "Temperature: $(flashchat_get TEMPERATURE) (randomness - higher = more creative)"
    echo "Top-p: $(flashchat_get TOP_P) (nucleus sampling - controls diversity)"
    echo "Top-k: $(flashchat_get TOP_K) | Min-p: $(flashchat_get MIN_P)"
    echo "Presence penalty: $(flashchat_get PRESENCE_PENALTY) | Repetition penalty: $(flashchat_get REPETITION_PENALTY)"
    local _ae_eff _ae_mdl
    _ae_eff="$(flashchat_effective_active_experts)"
    _ae_mdl="$(flashchat_model_active_experts "$(flashchat_get MODEL)")"
    local _ae_cfg
    _ae_cfg="$(flashchat_get ACTIVE_EXPERTS)"
    if [ -n "$_ae_cfg" ] && [ "$_ae_cfg" -gt "$FLASHCHAT_MAX_ACTIVE_EXPERTS" ] 2>/dev/null; then
        echo "Active experts (K): ${_ae_eff} (custom profile requested ${_ae_cfg}, clamped to runtime max ${FLASHCHAT_MAX_ACTIVE_EXPERTS}; model trained with K=${_ae_mdl:-?})"
    elif [ -n "$_ae_cfg" ] && [ "$_ae_cfg" -gt 0 ] 2>/dev/null; then
        echo "Active experts (K): ${_ae_eff} (custom profile override; model trained with K=${_ae_mdl:-?})"
    elif [ -n "${FLASHCHAT_ACTIVE_EXPERTS:-}" ] && [ "${FLASHCHAT_ACTIVE_EXPERTS}" -gt 0 ] 2>/dev/null; then
        echo "Active experts (K): ${_ae_eff} (FLASHCHAT_ACTIVE_EXPERTS override; model trained with K=${_ae_mdl:-?})"
    else
        echo "Active experts (K): ${_ae_eff} (from model registry num_experts_per_tok)"
    fi
    echo "Show thinking: $(flashchat_get SHOW_THINKING)"
    echo "System prompt cache: $(flashchat_get SYSTEM_PROMPT_CACHE) (max entries: $(flashchat_get SYSTEM_PROMPT_CACHE_MAX_ENTRIES))"
    echo "System prompt cache dir: $(flashchat_get SYSTEM_PROMPT_CACHE_DIR)"
    echo "Multi-token prediction: $(mtp_label "$MTP")"
    echo "Color output: $(flashchat_get COLOR_OUTPUT)"
    echo "User state: $(flashchat_get CONFIG_DIR)"
    echo "HuggingFace cache dir: $(flashchat_get HUGGINGFACE_CACHE_DIR)"
    echo "Offload dir: $(flashchat_get OFFLOAD_DIR)"
}

# -----------------------------------------------------------------------------
# Command: sessions
# -----------------------------------------------------------------------------
cmd_sessions() {
    local delete_id=""
    local list=1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --delete)
                delete_id="$2"
                list=0
                shift 2
                ;;
            -d)
                delete_id="$2"
                list=0
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    local sessions_dir
    sessions_dir=$(flashchat_get_sessions_dir)
    
    # Handle delete
    if [ -n "$delete_id" ]; then
        local session_file="$sessions_dir/${delete_id}.jsonl"
        if [ -f "$session_file" ]; then
            rm -f "$session_file"
            echo "Deleted session: $delete_id"
        else
            error "Session not found: $delete_id"
        fi
        return
    fi
    
    echo "=== Chat Sessions ==="
    echo ""
    
    if [ ! -d "$sessions_dir" ]; then
        echo "(no sessions)"
        return
    fi
    
    local count=0
    for f in "$sessions_dir"/*.jsonl; do
        [ -f "$f" ] || continue
        local session_id
        session_id=$(basename "$f" .jsonl)
        local lines
        lines=$(wc -l < "$f")
        local last_modified
        last_modified=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d' ' -f1)
        echo "  $session_id ($lines turns, $last_modified)"
        count=$((count + 1))
    done
    
    if [ $count -eq 0 ]; then
        echo "(no sessions)"
    else
        echo "To resume a session: flashchat chat --resume <session_id>"
        echo "To delete a session: flashchat sessions --delete <session_id>"
    fi
}
# -----------------------------------------------------------------------------
# Command: config — interactive wizard (Python: modelmgr)
# -----------------------------------------------------------------------------
cmd_config() {
    local reset_mode=0
    local full_reset=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reset) reset_mode=1; shift ;;
            --full-reset) reset_mode=1; full_reset=1; shift ;;
            *) break ;;
        esac
    done

    flashchat_load_config
    if [ "$full_reset" -eq 1 ]; then
        local config_file
        config_file=$(flashchat_get CONFIG_FILE)
        echo "Full reset removes your configuration and per-user model state."
        read -p "Continue? [y/N] " -n 1 -r || REPLY=""
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Cancelled."
            return 0
        fi
        rm -f "$config_file" \
              "$(flashchat_get CONFIG_DIR)/models.state.json" \
              "$(flashchat_get CONFIG_DIR)/resolved_models.json"
    fi
    ensure_venv
    if [ "$reset_mode" -eq 1 ]; then
        # A user cancelling onboarding is not a CLI failure.
        run_python -m modelmgr onboard || true
    else
        run_python -m modelmgr config
    fi
}

cmd_config_interactive() {
    # Clear env overrides so the wizard reflects the config file, not stale
    # values from previous serve runs.
    unset FLASHCHAT_REASONING FLASHCHAT_TEMPERATURE FLASHCHAT_TOP_P \
          FLASHCHAT_TOP_K FLASHCHAT_MIN_P FLASHCHAT_PRESENCE_PENALTY \
          FLASHCHAT_REPETITION_PENALTY FLASHCHAT_MODEL_PATH \
          FLASHCHAT_WEIGHTS_DIR FLASHCHAT_EXPERTS_DIR
    cmd_config "$@"
}

cmd_models() {
    ensure_venv
    run_python -m modelmgr status "$@"
}


cmd_manage() {
    flashchat_load_config
    ensure_venv
    if [ "${1:-}" = "--list" ] || [ "${1:-}" = "-l" ]; then
        run_python -m modelmgr status
        return
    fi
    run_python -m modelmgr manage
}

# -----------------------------------------------------------------------------
# Model readiness — quick non-interactive check, interactive repair on failure
# -----------------------------------------------------------------------------
ensure_model_ready() {
    ensure_venv
    if run_python -m modelmgr ensure --non-interactive >/dev/null 2>&1; then
        return 0
    fi
    run_python -m modelmgr ensure
}

FLASHCHAT_VENV=""

ensure_venv() {
    if [ -n "$FLASHCHAT_VENV" ] && [ -f "$FLASHCHAT_VENV/bin/python" ]; then
        if "$FLASHCHAT_VENV/bin/python" -c "import numpy, huggingface_hub" >/dev/null 2>&1; then
            return 0
        fi
        echo "Updating project virtual environment packages..."
        "$FLASHCHAT_VENV/bin/pip" install numpy huggingface_hub -q
        return 0
    fi

    FLASHCHAT_VENV="$SCRIPT_DIR/metal_infer/.venv"

    if [ ! -f "$FLASHCHAT_VENV/bin/python" ]; then
        echo "Creating Python virtual environment..."
        python3 -m venv "$FLASHCHAT_VENV"
    fi

    if ! "$FLASHCHAT_VENV/bin/python" -c "import numpy, huggingface_hub" >/dev/null 2>&1; then
        echo "Installing packages in project virtual environment..."
        "$FLASHCHAT_VENV/bin/pip" install numpy huggingface_hub -q
    fi
}

run_python() {
    ensure_venv
    # modelmgr lives at the repo root; steps import it as a package.
    PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" "$FLASHCHAT_VENV/bin/python" "$@"
}

check_binaries() {
    [ -f "$SCRIPT_DIR/metal_infer/infer" ] && [ -f "$SCRIPT_DIR/metal_infer/chat" ]
    return $?
}

file_newer_than() {
    local src="$1"
    local dst="$2"
    [ -f "$src" ] || return 1
    [ -f "$dst" ] || return 0
    [ "$(stat -f %m "$src" 2>/dev/null || echo 0)" -gt "$(stat -f %m "$dst" 2>/dev/null || echo 0)" ]
}

check_binaries_current() {
    check_binaries || return 1
    file_newer_than "$SCRIPT_DIR/metal_infer/infer.m" "$SCRIPT_DIR/metal_infer/infer" && return 1
    file_newer_than "$SCRIPT_DIR/metal_infer/model_config.h" "$SCRIPT_DIR/metal_infer/infer" && return 1
    file_newer_than "$SCRIPT_DIR/metal_infer/shaders.metal" "$SCRIPT_DIR/metal_infer/infer" && return 1
    file_newer_than "$SCRIPT_DIR/metal_infer/chat.m" "$SCRIPT_DIR/metal_infer/chat" && return 1
    file_newer_than "$SCRIPT_DIR/metal_infer/linenoise.c" "$SCRIPT_DIR/metal_infer/chat" && return 1
    return 0
}

ensure_binaries() {
    if check_binaries_current; then
        return 0
    fi
    
    echo "Binaries missing or stale. Building..."
    make -C "$SCRIPT_DIR" all chat
    
    if check_binaries_current; then
        echo "Build complete."
    else
        echo "ERROR: Build failed."
        exit 1
    fi
}

check_homebrew() {
    if command -v brew &> /dev/null; then
        return 0
    fi
    return 1
}

get_macos_version_label() {
    local version
    version=$(sw_vers -productVersion 2>/dev/null)
    local major="${version%%.*}"
    local codename="Unknown"

    case "$major" in
        11) codename="Big Sur" ;;
        12) codename="Monterey" ;;
        13) codename="Ventura" ;;
        14) codename="Sonoma" ;;
        15) codename="Sequoia" ;;
    esac

    if [ -n "$version" ]; then
        echo "macOS $version ($codename)"
    else
        echo "macOS (version unavailable)"
    fi
}

show_dependency_overview() {
    local os_label
    os_label=$(get_macos_version_label)
    local brew_version
    if check_homebrew; then
        brew_version=$(brew --version 2>/dev/null | head -1)
    else
        brew_version="Not installed yet"
    fi

    echo ""
    echo "=== Setup Dependencies ==="
    echo ""
    echo "Homebrew: package manager for macOS."
    echo "  Trusted open-source package manager for $os_label"
    echo "  Status: $brew_version"
    echo "  Repo: https://github.com/Homebrew/brew (47k stars, 11k forks as of 2026-04)"
    echo ""
    echo "Apple Xcode CLI: tools to build macOS and iOS apps from the command line."
    echo "  If prompted in another window, choose the default install options."
    echo ""
    echo "Hugging Face Hub utility for model download: https://huggingface.co"
    echo "  Installed in a temporary Python virtual environment and removed after model download."
    echo ""
    echo "NumPy: numerical computing library for Python: https://numpy.org"
    echo "  Installed in the project Python virtual environment for extraction/repack scripts."
    echo ""
}

bootstrap_homebrew_noninteractive() {
    if check_homebrew; then
        return 0
    fi

    echo "Homebrew is not installed."
    echo "Installing Homebrew automatically (NONINTERACTIVE=1)..."

    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi

    if check_homebrew; then
        echo "Homebrew installed successfully."
        return 0
    fi

    echo "ERROR: Homebrew install did not complete successfully."
    return 1
}


check_xcode_cli() {
    if xcode-select -p >/dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

prompt_install_xcode_cli() {
    echo ""
    echo "========================================"
    echo "  Ready to install tools for Flashchat?"
    echo "========================================"
    show_dependency_overview
    echo "  (X to exit the setup wizard)"
    read -p "Begin downloading the needed tools? [Y/x] " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Xx]$ ]]; then
        echo "User cancelled."
        echo "Re-run flashchat to begin the setup wizard."
        exit 0
    fi
    if ! [[ $REPLY =~ ^[Yy]$ ]] && [ -n "$REPLY" ]; then
        echo "Invalid selection. Re-run flashchat and choose Y or X."
        exit 1
    fi

    if ! check_homebrew; then
        if ! bootstrap_homebrew_noninteractive; then
            echo "Homebrew installation failed."
            echo "Continuing with Xcode CLI tools installation."
        fi
    fi

    echo ""
    echo "=== Xcode Command Line Tools Required ==="
    echo ""
    echo "Flashchat requires Xcode command line tools to compile the inference engine."
    echo "Without it, the model cannot run."
    echo ""
    read -p "Would you like to install Xcode CLI tools now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        echo "Installing Xcode command line tools..."
        echo "(This may prompt for your password)"
        xcode-select --install || true
        echo ""
        echo "If prompted in another window, choose default options."
        echo "Waiting for Xcode CLI tools to become available..."
        for _ in $(seq 1 120); do
            if check_xcode_cli; then
                echo "Xcode command line tools detected."
                return 0
            fi
            sleep 5
        done
        echo "Xcode CLI tools are still not detected."
        echo "Please finish installation, then run flashchat again."
        exit 0
    else
        echo "Cannot proceed without Xcode CLI tools. Exiting."
        exit 1
    fi
}

ensure_setup() {
    local force="${1:-0}"
    set +e
    if ! check_xcode_cli; then
        prompt_install_xcode_cli
    fi
    ensure_venv
    ensure_binaries
    run_python -m modelmgr ensure
    local rc=$?
    set -e
    return $rc
}
# Server management
# -----------------------------------------------------------------------------

is_server_running() {
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

file_signature_part() {
    local path="$1"
    if [ -f "$path" ]; then
        printf "%s:%s:%s" "$path" "$(stat -f %m "$path" 2>/dev/null || echo 0)" "$(cksum "$path" 2>/dev/null | awk '{print $1 ":" $2}')"
    else
        printf "%s:missing" "$path"
    fi
}

server_runtime_signature() {
    local effective_port="${1:-$(flashchat_get SERVER_PORT)}"
    {
        echo "MODEL=$(flashchat_get MODEL)"
        echo "MODEL_REPO=$(flashchat_get MODEL_REPO)"
        echo "MODEL_PATH=$(flashchat_get MODEL_PATH)"
        echo "MODEL_CONFIG=$(file_signature_part "$(flashchat_get MODEL_CONFIG)")"
        # Hash the whole user config file: the engine reads it directly, so ANY edit
        # to it must invalidate the running server. This makes the signature robust to
        # new settings without having to enumerate every key below.
        echo "CONFIG_FILE=$(file_signature_part "$(flashchat_get CONFIG_FILE)")"
        echo "SERVER_PORT=$effective_port"
        echo "TEMPERATURE=$(flashchat_get TEMPERATURE)"
        echo "SAMPLING_PROFILE=$(flashchat_get SAMPLING_PROFILE)"
        echo "REASONING=$(flashchat_get REASONING)"
        echo "TOP_P=$(flashchat_get TOP_P)"
        echo "TOP_K=$(flashchat_get TOP_K)"
        echo "MIN_P=$(flashchat_get MIN_P)"
        echo "PRESENCE_PENALTY=$(flashchat_get PRESENCE_PENALTY)"
        echo "REPETITION_PENALTY=$(flashchat_get REPETITION_PENALTY)"
        echo "SERVER_LOG_PATH=$(flashchat_get SERVER_LOG_PATH)"
        echo "SERVER_DEBUG=$(flashchat_get SERVER_DEBUG)"
        echo "SERVER_HTTP_LOG=$(flashchat_get SERVER_HTTP_LOG)"
        echo "SHOW_THINKING=$(flashchat_get SHOW_THINKING)"
        echo "SYSTEM_PROMPT_CACHE=$(flashchat_get SYSTEM_PROMPT_CACHE)"
        echo "SYSTEM_PROMPT_CACHE_MAX_ENTRIES=$(flashchat_get SYSTEM_PROMPT_CACHE_MAX_ENTRIES)"
        echo "SYSTEM_PROMPT_CACHE_DIR=$(flashchat_get SYSTEM_PROMPT_CACHE_DIR)"
        echo "MTP=$(flashchat_get MTP)"
        echo "INFER_BIN=$(file_signature_part "$SCRIPT_DIR/metal_infer/infer")"
        echo "INFER_SRC=$(file_signature_part "$SCRIPT_DIR/metal_infer/infer.m")"
        echo "MODEL_CONFIG_SRC=$(file_signature_part "$SCRIPT_DIR/metal_infer/model_config.h")"
        echo "SHADERS_SRC=$(file_signature_part "$SCRIPT_DIR/metal_infer/shaders.metal")"
    } | cksum | awk '{print $1 ":" $2}'
}

server_signature_matches_config() {
    local effective_port="${1:-$(flashchat_get SERVER_PORT)}"
    local signature_file
    signature_file=$(flashchat_get_server_signature_file)
    [ -f "$signature_file" ] || return 1
    [ "$(cat "$signature_file" 2>/dev/null)" = "$(server_runtime_signature "$effective_port")" ]
}

write_server_signature() {
    local effective_port="${1:-$(flashchat_get SERVER_PORT)}"
    local signature_file
    signature_file=$(flashchat_get_server_signature_file)
    mkdir -p "$(dirname "$signature_file")"
    server_runtime_signature "$effective_port" > "$signature_file"
}

clear_server_signature() {
    rm -f "$(flashchat_get_server_signature_file)"
}

restart_stale_owned_server() {
    local port="$1"
    local ask_force=0
    if [ "${2:-}" = "--ask-force" ]; then
        ask_force=1
    fi

    if is_server_running && ! server_signature_matches_config "$port"; then
        echo "Configured runtime changed; restarting Flashchat server..."
        if ! cmd_serve --stop --port "$port"; then
            if [ "$ask_force" -eq 0 ]; then
                return 1
            fi

            local reply=""
            if ! read -p "Server did not stop cleanly. Force stop and restart it? [Y/n] " -n 1 -r reply; then
                echo ""
                return 1
            fi
            echo ""
            if [[ $reply =~ ^[Nn]$ ]]; then
                return 1
            fi

            if ! cmd_serve --stop --force --port "$port"; then
                return 1
            fi
        fi

        if ! cmd_serve --port "$port"; then
            return 1
        fi
    fi
    return 0
}

is_server_healthy() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    curl -fsS --max-time 2 "http://${host}:${port}/health" >/dev/null 2>&1
}

wait_for_server() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    local max_wait=30
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        if nc -z "$host" "$port" 2>/dev/null && is_server_healthy "$port"; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_pid_exit() {
    local pid="$1"
    local timeout="${2:-10}"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

wait_for_port_clear() {
    local port="$1"
    local timeout="${2:-10}"
    local host
    host="$(flashchat_server_connect_host)"
    local waited=0

    while [ "$waited" -lt "$timeout" ]; do
        if ! is_port_listening "$port"; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

get_port_listener_pid() {
    local port="$1"
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -Fp 2>/dev/null | awk '/^p/ { print substr($0, 2); exit }'
}

get_port_listener_command() {
    local port="$1"
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -Fc 2>/dev/null | awk '/^c/ { print substr($0, 2); exit }'
}

is_port_listening() {
    local port="$1"
    local host
    host="$(flashchat_server_connect_host)"
    if nc -z "$host" "$port" 2>/dev/null; then
        return 0
    fi
    [ -n "$(get_port_listener_pid "$port")" ]
}

is_flashchat_infer_command() {
    local command_name="$1"
    case "$command_name" in
        infer|metal_infer/infer|*/metal_infer/infer|*/infer)
            return 0
            ;;
    esac
    return 1
}

stop_external_server() {
    local server_port="$1"
    local force="$2"
    local pid command_name

    pid=$(get_port_listener_pid "$server_port")
    command_name=$(get_port_listener_command "$server_port")

    if [ -z "$pid" ]; then
        echo "Server port $server_port is in use but the owning process could not be found."
        echo "Use 'lsof -i :$server_port' to inspect it manually."
        return 1
    fi

    if ! is_flashchat_infer_command "$command_name"; then
        echo "Refusing to stop the process listening on port $server_port."
        echo "It does not look like Flashchat's infer server: ${command_name:-unknown} (PID: $pid)"
        return 1
    fi

    echo "Stopping external Flashchat server (PID: $pid, command: $command_name)..."
    kill "$pid" 2>/dev/null || true
    if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
        echo "External server stopped."
        return 0
    fi

    if [ "$force" -eq 1 ]; then
        echo "External server did not exit after waiting. Sending SIGKILL..."
        kill -9 "$pid" 2>/dev/null || true
        if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
            echo "External server force-stopped."
            return 0
        fi
        error "External server process $pid is still present after SIGKILL"
    fi

    echo "External server is still running after SIGTERM."
    echo "Try: flashchat serve --stop --external --force"
    return 1
}

find_available_port() {
    local start_port="$1"
    local port="$start_port"
    local host
    host="$(flashchat_server_connect_host)"
    
    while [ $port -lt $((start_port + 10)) ]; do
        if ! is_port_listening "$port"; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    
    echo "$start_port"
    return 1
}


cmd_serve() {
    local stop=0
    local force=0
    local external=0
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stop)
                stop=1
                shift
                ;;
            --stop-external)
                stop=1
                external=1
                shift
                ;;
            --external)
                external=1
                shift
                ;;
            --force)
                force=1
                shift
                ;;
            -p|--port)
                port="$2"
                shift 2
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done
    
    if [ "$stop" -eq 1 ]; then
        flashchat_load_config
        set +m  # Disable job control to suppress termination messages
        local pid_file
        local server_port
        pid_file=$(flashchat_get_pid_file)
        server_port="${port:-$(flashchat_get SERVER_PORT)}"

        if [ -f "$pid_file" ]; then
            local pid
            pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                echo "Stopping server (PID: $pid)..."
                kill "$pid" 2>/dev/null
                if wait_for_pid_exit "$pid" 10 && wait_for_port_clear "$server_port" 10; then
                    rm -f "$pid_file"
                    clear_server_signature
                    echo "Server stopped."
                elif [ "$force" -eq 1 ]; then
                    echo "Server did not exit after waiting. Sending SIGKILL..."
                    kill -9 "$pid" 2>/dev/null || true
                    if wait_for_pid_exit "$pid" 5 && wait_for_port_clear "$server_port" 5; then
                        rm -f "$pid_file"
                        clear_server_signature
                        echo "Server force-stopped."
                    else
                        error "Server process $pid is still present after SIGKILL"
                    fi
                else
                    echo "Server is still running after SIGTERM."
                    echo "Try: flashchat serve --stop --force"
                    return 1
                fi
            else
                echo "Server not running (stale PID file)."
                rm -f "$pid_file"
                clear_server_signature
            fi
        elif is_port_listening "$server_port"; then
            if [ "$external" -eq 1 ]; then
                stop_external_server "$server_port" "$force"
            else
                echo "An external server is listening on port $server_port."
                echo "Use 'flashchat serve --stop --external' to stop it after confirming it is Flashchat's infer server."
                return 1
            fi
        else
            echo "No server running."
        fi
        return
    fi
    
    # Start server
    flashchat_load_config
    
    # Verify the model is ready (download/extract/repair via Python core)
    ensure_model_ready
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    # Check if WE already started the server
    if is_server_running; then
        if server_signature_matches_config; then
            echo "Server is already running (PID: $(cat "$(flashchat_get_pid_file)"))."
            return
        fi
        echo "Server is running with stale runtime settings."
        echo "Restarting server to apply the current configuration..."
        cmd_serve --stop --port "$server_port"
    fi

    # Rebuild after any stale server has stopped, so source/config changes are reflected.
    ensure_binaries

    # Check again in case stop failed or an external process took the port.
    if is_server_running; then
        echo "Server is already running (PID: $(cat "$(flashchat_get_pid_file)"))."
        return
    fi
    
    # Check if port is available (may be used by another process)
    if is_port_listening "$server_port"; then
        echo "Port $server_port is in use by another process."
        local suggested
        suggested=$(find_available_port $((server_port + 1)))
        echo "Suggested available port: $suggested"
        read -p "Use port $suggested instead? [Y/n] " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
            server_port="$suggested"
        else
            error "Cannot start server on port $server_port"
        fi
    fi
    
    # Start server in background
    local pid_file
    pid_file=$(flashchat_get_pid_file)
    
    # Launch infer with config as the single source of truth for persistent
    # settings (sampling, MTP, cache, reasoning, model id): the engine reads the
    # config file directly via --config. Launch-resolved values (the model weights
    # path) are passed as explicit CLI flags, visible in `ps`. There is no longer an
    # env bridge for settings — a stray FLASHCHAT_TEMPERATURE/FLASHCHAT_MTP in the
    # shell is intentionally ignored by the engine; edit the config to change them.
    # Only infra paths/flags (log destination, sessions/system-prompt/registry
    # locations) are still passed via the environment.
    local _model_path _config_file _server_log _server_debug _server_http_log
    _model_path="$(flashchat_get MODEL_PATH)"
    _config_file="$(flashchat_get CONFIG_FILE)"
    [ -n "${FLASHCHAT_SERVER_LOG}" ]      && _server_log="$FLASHCHAT_SERVER_LOG"           || _server_log="$(flashchat_get SERVER_LOG_PATH)"
    [ -n "${FLASHCHAT_SERVER_DEBUG}" ]    && _server_debug="$FLASHCHAT_SERVER_DEBUG"       || _server_debug="$(flashchat_get SERVER_DEBUG)"
    [ -n "${FLASHCHAT_SERVER_HTTP_LOG}" ] && _server_http_log="$FLASHCHAT_SERVER_HTTP_LOG" || _server_http_log="$(flashchat_get SERVER_HTTP_LOG)"

    FLASHCHAT_SERVER_LOG="$_server_log" \
    FLASHCHAT_SERVER_DEBUG="$_server_debug" \
    FLASHCHAT_SERVER_HTTP_LOG="$_server_http_log" \
    FLASHCHAT_SESSIONS_DIR="$(flashchat_get SESSIONS_DIR)" \
    FLASHCHAT_SYSTEM_PROMPT="$(flashchat_get_system_prompt_file)" \
    FLASHCHAT_MODEL_CONFIG="$(flashchat_get MODEL_CONFIG)" \
    FLASHCHAT_ACTIVE_EXPERTS="$(flashchat_get ACTIVE_EXPERTS)" \
    "$SCRIPT_DIR/metal_infer/infer" --serve "$server_port" \
        --config "$_config_file" --model "$_model_path" > /dev/null 2>&1 &
    local infer_pid=$!
    
    # Wait for server to be ready
    echo "Starting server on port $server_port..."
    if wait_for_server "$server_port"; then
        echo "$infer_pid" > "$pid_file"
        write_server_signature "$server_port"
        echo "Server running (PID: $infer_pid)"
        echo "API available at http://$server_host:$server_port"
        echo ""
        echo "Endpoints:"
        echo "  POST /v1/chat/completions"
        echo "  POST /v1/responses"
        echo "  GET  /v1/models"
        echo "  GET  /health"
        echo ""
        echo "To stop: flashchat serve --stop"
    else
        rm -f "$pid_file"
        clear_server_signature
        error "Server failed to start"
    fi
}

cmd_chat() {
    local resume_id=""
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume)
                resume_id="$2"
                shift 2
                ;;
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashchat_load_config
    
    # Quick readiness check only: chat/prompt are reached via ensure_setup
    # (CLI) or the menu's ensure; an interactive repair here would steal
    # stdin from the session. Warn and proceed (server may already run).
    if ! run_python -m modelmgr ensure --non-interactive >/dev/null 2>&1; then
        echo "Note: the configured model is not fully set up — run './flashchat config' if this fails."
    fi

    local thinking_guard_rc
    set +e
    confirm_show_thinking_for_chat
    thinking_guard_rc=$?
    set -e
    if [ "$thinking_guard_rc" -eq 2 ]; then
        return 0
    elif [ "$thinking_guard_rc" -ne 0 ]; then
        return "$thinking_guard_rc"
    fi
    
    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    if ! restart_stale_owned_server "$server_port" --ask-force; then
        echo "Server restart was not completed."
        return 1
    fi

    # Start server if not running
    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Launch chat
    ensure_binaries
    local old_pwd
    old_pwd="$(pwd)"
    cd "$SCRIPT_DIR/metal_infer"
    
    local chat_args=""
    [ -n "$server_port" ] && chat_args="--port $server_port"
    [ -n "$server_host" ] && chat_args="$chat_args --host $server_host"
    [ -n "$resume_id" ] && chat_args="$chat_args --resume $resume_id"
    # Honor the configured response length (max tokens per response) in the chat
    # client too, so config MAX_TOKENS applies consistently (chat + one-shot prompt).
    local _max_tokens
    _max_tokens="$(flashchat_get MAX_TOKENS)"
    [ -n "$_max_tokens" ] && chat_args="$chat_args --max-tokens $_max_tokens"
    
    FLASHCHAT_MODEL="$(flashchat_get MODEL)" \
    FLASHCHAT_SERVER_HOST="$server_host" \
    FLASHCHAT_REASONING="$(flashchat_get REASONING)" \
    FLASHCHAT_SHOW_THINKING="$(flashchat_get SHOW_THINKING)" \
    FLASHCHAT_SESSIONS_DIR="$(flashchat_get sessions_dir)" \
    ./chat $chat_args
    
    cd "$old_pwd"
}

cmd_prompt() {
    local prompt="$1"
    
    if [ -z "$prompt" ]; then
        error "Usage: flashchat prompt \"your message here\""
    fi
    
    flashchat_load_config
    
    # Quick readiness check only: chat/prompt are reached via ensure_setup
    # (CLI) or the menu's ensure; an interactive repair here would steal
    # stdin from the session. Warn and proceed (server may already run).
    if ! run_python -m modelmgr ensure --non-interactive >/dev/null 2>&1; then
        echo "Note: the configured model is not fully set up — run './flashchat config' if this fails."
    fi
    
    local server_port
    server_port=$(flashchat_get SERVER_PORT)
    local server_host
    server_host="$(flashchat_server_connect_host)"
    
    if ! restart_stale_owned_server "$server_port"; then
        error "Server restart was not completed"
    fi

    # Start server if not running
    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Wait for server
    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi
    
    # Send request
    curl -s -N -X POST "http://$server_host:$server_port/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"role\":\"user\",\"content\":\"$prompt\"}],\"max_tokens\":$(flashchat_get MAX_TOKENS),\"reasoning\":$(flashchat_get REASONING),\"temperature\":$(flashchat_get TEMPERATURE),\"top_p\":$(flashchat_get TOP_P),\"top_k\":$(flashchat_get TOP_K),\"min_p\":$(flashchat_get MIN_P),\"presence_penalty\":$(flashchat_get PRESENCE_PENALTY),\"repetition_penalty\":$(flashchat_get REPETITION_PENALTY)}"
    echo ""
}

cmd_opencode() {
    local port=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done

    flashchat_load_config

    if ! command -v opencode >/dev/null 2>&1; then
        error "OpenCode CLI not found in PATH"
    fi

    local server_port
    server_port="${port:-$(flashchat_get SERVER_PORT)}"
    local server_host
    server_host="$(flashchat_server_connect_host)"

    if ! restart_stale_owned_server "$server_port" --ask-force; then
        echo "Server restart was not completed."
        return 1
    fi

    if ! is_port_listening "$server_port"; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi

    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi

    if ! check_opencode_config "$server_port" "$server_host"; then
        error "OpenCode config is missing or incomplete"
    fi

    echo "Launching OpenCode against http://${server_host}:${server_port}/v1"
    cd "$SCRIPT_DIR"
    opencode "$@"
}

# -----------------------------------------------------------------------------
# Interactive menu
# -----------------------------------------------------------------------------
interactive_menu() {
    flashchat_load_config
    
    # Setup/repair may be declined or fail; the menu stays usable either way
    # (server controls, config wizard, manage all work without a ready model).
    # Interactive repair only on a real terminal: Python's input() buffers the
    # whole stdin pipe, which would swallow the menu's piped/scripted input.
    if [ -t 0 ]; then
        if [ ! -f "$(flashchat_get CONFIG_FILE)" ]; then
            echo "Welcome to Flashchat. Running initial setup..."
            ensure_setup || echo "Setup incomplete — run './flashchat config' to finish."
        else
            # Config exists — verify the model is ready, repair if not
            ensure_model_ready || echo "Model not ready — use [C]onfig to finish setup."
        fi
    else
        ensure_venv
        run_python -m modelmgr ensure --non-interactive >/dev/null 2>&1 \
            || echo "Model not ready — run './flashchat config' to finish setup."
    fi
    
    while true; do
        flashchat_load_config
        
        local server_status="Not running"
        if is_server_running; then
            if server_signature_matches_config; then
                server_status="Running"
            else
                server_status="Running (restart needed)"
            fi
        elif is_port_listening "$(flashchat_get SERVER_PORT)"; then
            server_status="Running (external)"
        fi
        
        # Model readiness comes from the Python core (quick checks only)
        local setup_status="Not ready"
        if run_python -m modelmgr ensure --non-interactive >/dev/null 2>&1; then
            setup_status="Ready"
        fi
        
        local server_url="http://$(flashchat_get SERVER_HOST):$(flashchat_get SERVER_PORT)/v1"
        
        local server_line="Server: $server_status"
        if [ "$server_status" = "Running" ] || [ "$server_status" = "Running (external)" ] || [ "$server_status" = "Running (restart needed)" ]; then
            server_line="$server_line   API: $server_url"
        fi
        
        echo ""
        echo "=================================================="
        echo "           Flashchat Management"
        echo "=================================================="
        echo "Status: $setup_status at $server_url"
        echo "Model: $(flashchat_get MODEL)"
        echo "Quantization: $(current_quantization_label)"
        echo "$server_line"
        echo "[N]ew [D]ialog, Server [O]n/[O]ff, [S]how [C]onfig, [M]anage, [Q]uit"
        read -p "> " -n 1 -r || { echo ""; echo "Goodbye!"; break; }

        case "$REPLY" in
            n|N)
                echo ""
                if ! cmd_chat; then
                    echo "New dialog was not started."
                fi
                ;;
            d|D)
                echo ""
                echo "Select a chat dialog to resume:"
                echo ""
                
                # Get sessions list
                local sessions_dir
                sessions_dir=$(flashchat_get_sessions_dir)
                
                if [ ! -d "$sessions_dir" ]; then
                    echo "  (no chat dialogs found)"
                    echo ""
                else
                    local count=0
                    local session_ids=()
                    
                    for f in "$sessions_dir"/*.jsonl; do
                        [ -f "$f" ] || continue
                        local session_id
                        session_id=$(basename "$f" .jsonl)
                        local lines
                        lines=$(wc -l < "$f")
                        count=$((count + 1))
                        session_ids+=("$session_id")
                        echo "  [$count] $session_id ($lines turns)"
                    done
                    
                    if [ $count -eq 0 ]; then
                        echo "  (no chat dialogs)"
                    else
                        echo ""
                        echo -n "Enter number or chat dialog ID: "
                        read -r session_id
                        
                        # Check if input is a number
                        if [[ "$session_id" =~ ^[0-9]+$ ]] && [ "$session_id" -le $count ] && [ "$session_id" -gt 0 ]; then
                            session_id="${session_ids[$((session_id - 1))]}"
                        fi
                        
                        if [ -n "$session_id" ]; then
                            if ! cmd_chat --resume "$session_id"; then
                                echo "Dialog was not resumed."
                            fi
                        fi
                    fi
                fi
                ;;
            s|S)
                echo ""
                cmd_status
                ;;
            o|O)
                echo ""
                if is_server_running; then
                    if ! cmd_serve --stop; then
                        read -p "Server is not responding. Force stop the server? [Y/n] " -n 1 -r
                        echo ""
                        if [[ $REPLY =~ ^[Nn]$ ]]; then
                            :
                        else
                            cmd_serve --stop --force
                        fi
                    fi
                elif [ "$server_status" = "Running (external)" ]; then
                    echo "A server is already listening at $(flashchat_server_connect_host):$(flashchat_get SERVER_PORT), but Flashchat does not own its pid file."
                    read -p "Stop this external Flashchat server? [y/N] " -n 1 -r
                    echo ""
                    if [[ $REPLY =~ ^[Yy]$ ]]; then
                        if ! cmd_serve --stop --external; then
                            read -p "External server did not stop cleanly. Force stop it? [y/N] " -n 1 -r
                            echo ""
                            if [[ $REPLY =~ ^[Yy]$ ]]; then
                                cmd_serve --stop --external --force
                            fi
                        fi
                    fi
                else
                    cmd_serve
                fi
                ;;
            c|C)
                cmd_config_interactive
                ;;
            m|M)
                echo ""
                cmd_manage
                ;;
            q|Q)
                echo ""
                echo "Goodbye!"
                break
                ;;
            *)
                echo ""
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Command: benchmark
# -----------------------------------------------------------------------------
cmd_benchmark() {
    local target=""
    
    if [ $# -eq 0 ]; then
        echo "=== Available Benchmarks ==="
        echo ""
        echo "  run         - Single expert forward pass"
        echo "  verify      - Metal vs CPU reference verification"
        echo "  bench       - Benchmark single expert (10 iterations)"
        echo "  moe         - Full MoE forward (K experts, single layer)"
        echo "  moebench    - Benchmark MoE (10 iterations)"
        echo "  full        - Full model forward (K=4)"
        echo "  fullbench   - Benchmark full forward (3 iterations)"
        echo ""
        echo "Usage: flashchat benchmark <target>"
        echo "Example: flashchat benchmark fullbench"
        return
    fi
    
    target="$1"
    
    # Load config and pass environment variables directly to make
    # without `export` so they do not leak into the parent shell.
    flashchat_load_config
    local _model_path _weights_dir _experts_dir _model_config _sessions_dir _system_prompt
    _model_path="$(flashchat_get MODEL_PATH)"
    _weights_dir="$(flashchat_get WEIGHTS_DIR)"
    _experts_dir="$(flashchat_get EXPERTS_DIR)"
    _model_config="$(flashchat_get MODEL_CONFIG)"
    _sessions_dir="$(flashchat_get sessions_dir)"
    _system_prompt="$(flashchat_get system_prompt_file)"
    
    ensure_binaries
    
    case "$target" in
        run)
            echo "Running: single expert forward pass..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" run
            ;;
        verify)
            echo "Running: Metal vs CPU verification..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" verify
            ;;
        bench)
            echo "Running: single expert benchmark (10 iterations)..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" bench
            ;;
        moe)
            echo "Running: MoE forward (K experts, single layer)..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" moe
            ;;
        moebench)
            echo "Running: MoE benchmark (10 iterations)..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" moebench
            ;;
        full)
            echo "Running: Full model forward (K=4)..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" full
            ;;
        fullbench)
            echo "Running: Full benchmark (3 iterations)..."
            FLASHCHAT_MODEL_PATH="$_model_path" FLASHCHAT_WEIGHTS_DIR="$_weights_dir" \
                FLASHCHAT_EXPERTS_DIR="$_experts_dir" FLASHCHAT_MODEL_CONFIG="$_model_config" \
                FLASHCHAT_SESSIONS_DIR="$_sessions_dir" FLASHCHAT_SYSTEM_PROMPT="$_system_prompt" \
                make -C "$SCRIPT_DIR" fullbench
            ;;
        *)
            echo "Unknown benchmark: $target"
            echo "Run 'flashchat benchmark' to see available targets."
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            --config)
                CONFIG_FILE="$2"
                FLASHCHAT_CONFIG_FILE_OVERRIDE="$2"
                export FLASHCHAT_CONFIG_FILE_OVERRIDE
                shift 2
                ;;
            --model)
                export FLASHCHAT_MODEL="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done
    
    if [ $# -eq 0 ]; then
        interactive_menu
        return
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h)
            show_help
            ;;
        status)
            cmd_status "$@"
            ;;
        sessions)
            cmd_sessions "$@"
            ;;
        models)
            cmd_models "$@"
            ;;
        manage)
            cmd_manage "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        chat)
            ensure_setup
            cmd_chat "$@"
            ;;
        serve)
            cmd_serve "$@"
            ;;
        prompt)
            ensure_setup
            cmd_prompt "$@"
            ;;
        opencode)
            ensure_setup
            cmd_opencode "$@"
            ;;
        benchmark)
            cmd_benchmark "$@"
            ;;
        migrate|doctor|verify)
            flashchat_load_config
            ensure_venv
            run_python -m modelmgr "$command" "$@"
            ;;
        *)
            error "Unknown command: $command"
            ;;
    esac
}

main "$@"
