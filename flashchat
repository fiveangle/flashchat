    # Check if model is supported
    local model_id
    model_id=$(flashchat_get MODEL)
    local model_config
    model_config=$(flashchat_get MODEL_CONFIG)
    if [ -f "$model_config" ] && command -v python3 >/dev/null 2>&1; then
