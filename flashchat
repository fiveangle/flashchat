#!/bin/bash
# flashchat — Flash-MoE Unified Management CLI
#
# Usage:
#   flashchat [command] [options]
#
# Commands:
#   chat              Start chat (auto-sets up if missing)
#   chat --resume ID  Resume session
#   serve             Start API server (auto-sets up if missing)
#   serve --stop      Stop running server
#   prompt "..."      Single prompt (auto-sets up if missing)
#   config            Edit/show configuration
#   status            Show system status
#   sessions          List sessions
#   help              Show this help
#
# Options:
#   --config FILE     Use specific config
#   -v, --verbose    Verbose output
#   -q, --quiet      Quiet mode
#
# Configuration:
#   Config is loaded from (priority highest to lowest):
#     1. ./flashmoe.config (project-local)
#     2. ~/.config/flash-moe/config (user)
#     3. Environment variables (FLASHMOE_*)
#     4. Hardcoded defaults

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib/config.sh"

# Global flags
VERBOSE=0
QUIET=0
CONFIG_FILE=""

# -----------------------------------------------------------------------------
# Helper functions
# -----------------------------------------------------------------------------

log() {
    [ "$QUIET" -eq 0 ] && echo "$@"
}

logv() {
    [ "$VERBOSE" -eq 1 ] && echo "[DEBUG] $@"
}

error() {
    echo "ERROR: $@" >&2
    exit 1
}

# -----------------------------------------------------------------------------
# Parse global options
# -----------------------------------------------------------------------------
parse_global_opts() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -q|--quiet)
                QUIET=1
                shift
                ;;
            --config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                break
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Show help
# -----------------------------------------------------------------------------
show_help() {
    cat << EOF
flashchat — Flash-MoE Unified Management CLI

Usage:
  flashchat [command] [options]

Commands:
  chat              Start chat (auto-sets up if missing)
  chat --resume ID  Resume session
  serve             Start API server (auto-sets up if missing)
  serve --stop      Stop running server
  prompt "..."      Single prompt (auto-sets up if missing)
  config            Edit configuration
  status            Show system status
  sessions          List sessions
  help              Show this help

Options:
  --config FILE     Use specific config file
  -v, --verbose    Verbose output
  -q, --quiet      Quiet mode

Configuration:
  Config is loaded from (priority highest to lowest):
    1. ./flashmoe.config (project-local)
    2. ~/.config/flash-moe/config (user)
    3. Environment variables (FLASHMOE_*)
    4. Hardcoded defaults

Environment variables:
  FLASHMOE_MODEL_REPO      HuggingFace repo (default: mlx-community/Qwen3.5-397B-A17B-4bit)
  FLASHMOE_MODEL_PATH      Override model path
  FLASHMOE_QUANTIZATION   4bit or 2bit
  FLASHMOE_SERVER_PORT    Server port
  FLASHMOE_WEIGHTS_DIR    Path to extracted weights
  FLASHMOE_EXPERTS_DIR   Path to expert weights

For more info, see: https://github.com/flash-moE/flash-moe
EOF
}

# -----------------------------------------------------------------------------
# Command: status
# -----------------------------------------------------------------------------
cmd_status() {
    flashmoe_load_config
    
    echo "=== Flash-MoE Status ==="
    echo ""
    echo "Model:"
    echo "  Repository: $(flashmoe_get MODEL_REPO)"
    echo "  Path: $(flashmoe_get MODEL_PATH)"
    echo "  Quantization: $(flashmoe_get QUANTIZATION)"
    echo ""
    echo "Paths:"
    echo "  Weights: $(flashmoe_get WEIGHTS_DIR)"
    echo "  Experts: $(flashmoe_get EXPERTS_DIR)"
    echo "  Experts (2bit): $(flashmoe_get EXPERTS_2BIT_DIR)"
    echo ""
    echo "Server:"
    echo "  Port: $(flashmoe_get SERVER_PORT)"
    echo "  Host: $(flashmoe_get SERVER_HOST)"
    
    # Check if server is running
    local pid_file
    pid_file=$(flashmoe_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            echo "  Status: Running (PID: $pid)"
        else
            echo "  Status: Not running (stale PID file)"
        fi
    else
        echo "  Status: Not running"
    fi
    
    echo ""
    echo "Generation:"
    echo "  Max tokens: $(flashmoe_get MAX_TOKENS)"
    echo "  Temperature: $(flashmoe_get TEMPERATURE)"
    echo "  Top-p: $(flashmoe_get TOP_P)"
}

# -----------------------------------------------------------------------------
# Command: sessions
# -----------------------------------------------------------------------------
cmd_sessions() {
    local delete_id=""
    local list=1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --delete)
                delete_id="$2"
                list=0
                shift 2
                ;;
            -d)
                delete_id="$2"
                list=0
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashmoe_load_config
    
    local sessions_dir
    sessions_dir=$(flashmoe_get_sessions_dir)
    
    # Handle delete
    if [ -n "$delete_id" ]; then
        local session_file="$sessions_dir/${delete_id}.jsonl"
        if [ -f "$session_file" ]; then
            rm -f "$session_file"
            echo "Deleted session: $delete_id"
        else
            error "Session not found: $delete_id"
        fi
        return
    fi
    
    echo "=== Chat Sessions ==="
    echo ""
    echo "Usage: flashchat sessions [--delete <id>]"
    echo ""
    
    if [ ! -d "$sessions_dir" ]; then
        echo "No sessions directory found."
        return
    fi
    
    local count=0
    for f in "$sessions_dir"/*.jsonl; do
        [ -f "$f" ] || continue
        local session_id
        session_id=$(basename "$f" .jsonl)
        local lines
        lines=$(wc -l < "$f")
        local last_modified
        last_modified=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d' ' -f1)
        echo "  $session_id"
        echo "    Turns: $lines"
        echo "    Last modified: $last_modified"
        echo ""
        count=$((count + 1))
    done
    
    if [ $count -eq 0 ]; then
        echo "  (no sessions)"
    else
        echo "To resume a session: flashchat chat --resume <session_id>"
        echo "To delete a session: flashchat sessions --delete <session_id>"
    fi
}

# -----------------------------------------------------------------------------
# Command: config
# -----------------------------------------------------------------------------
cmd_config() {
    local reset_mode=""
    local full_reset=0
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reset)
                reset_mode="environment"
                shift
                ;;
            --full-reset)
                reset_mode="environment"
                full_reset=1
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashmoe_load_config
    
    local config_file
    config_file=$(flashmoe_get CONFIG_FILE)
    
    # Handle reset modes
    if [ "$reset_mode" = "environment" ]; then
        if [ $full_reset -eq 1 ]; then
            echo "=== Full Reset ==="
            echo ""
            echo "This will delete ALL data including:"
            echo "  - Configuration"
            echo "  - All chat sessions"
            echo "  - All settings"
            echo ""
            read -p "Are you sure? [y/N] " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                rm -f "$config_file"
                rm -rf "$(flashmoe_get_sessions_dir)"
                echo "Full reset complete. All data deleted."
            else
                echo "Cancelled."
            fi
        else
            echo "=== Reset Environment ==="
            echo ""
            echo "This will re-run the setup wizard."
            echo "Your chat sessions will be preserved."
            echo ""
            read -p "Continue? [Y/n] " -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
                rm -f "$config_file"
                echo ""
                echo "Config removed. Re-running setup..."
                echo ""
                # Re-run setup wizard with force mode
                ensure_setup 1
            else
                echo "Cancelled."
            fi
        fi
        return
    fi
    
    if [ -z "$config_file" ]; then
        echo "No config file found. Creating default..."
        flashmoe_create_default_config
        flashmoe_load_config
        config_file=$(flashmoe_get CONFIG_FILE)
    fi
    
    echo "=== Flash-MoE Configuration ==="
    echo ""
    echo "Config file: $config_file"
    echo ""
    echo "Current settings:"
    echo ""
    echo "Model:"
    echo "  MODEL_REPO:      $(flashmoe_get MODEL_REPO)"
    echo "  MODEL_PATH:      $(flashmoe_get MODEL_PATH)"
    echo "  QUANTIZATION:    $(flashmoe_get QUANTIZATION)"
    echo ""
    echo "Generation:"
    echo "  MAX_TOKENS:      $(flashmoe_get MAX_TOKENS)"
    echo "  TEMPERATURE:     $(flashmoe_get TEMPERATURE)"
    echo "  TOP_P:           $(flashmoe_get TOP_P)"
    echo ""
    echo "Server:"
    echo "  SERVER_PORT:     $(flashmoe_get SERVER_PORT)"
    echo "  SERVER_HOST:     $(flashmoe_get SERVER_HOST)"
    echo ""
    echo "UI:"
    echo "  SHOW_THINKING:   $(flashmoe_get SHOW_THINKING)"
    echo "  COLOR_OUTPUT:    $(flashmoe_get COLOR_OUTPUT)"
    echo ""
    echo "Options:"
    echo "  flashchat config --reset      Re-run setup wizard (keep sessions)"
    echo "  flashchat config --full-reset Delete everything"
    echo ""
    echo "To modify, edit: $config_file"
}

# -----------------------------------------------------------------------------
# Auto-setup functions
# -----------------------------------------------------------------------------

check_model_downloaded() {
    local model_path
    model_path=$(flashmoe_get MODEL_PATH)
    [ -d "$model_path" ] && [ -f "$model_path/model.safetensors.index.json" ]
    return $?
}

check_weights_extracted() {
    local weights_dir
    weights_dir=$(flashmoe_get WEIGHTS_DIR)
    [ -f "$weights_dir/model_weights.bin" ] && [ -f "$weights_dir/model_weights.json" ]
    return $?
}

check_vocab_exported() {
    local weights_dir
    weights_dir=$(flashmoe_get WEIGHTS_DIR)
    [ -f "$weights_dir/vocab.bin" ]
    return $?
}

check_experts_extracted() {
    local experts_dir
    experts_dir=$(flashmoe_get EXPERTS_DIR)
    [ -f "$experts_dir/layer_00.bin" ]
    return $?
}

check_experts_2bit_extracted() {
    local experts_2bit_dir
    experts_2bit_dir=$(flashmoe_get EXPERTS_2BIT_DIR)
    [ -f "$experts_2bit_dir/layer_00.bin" ]
    return $?
}

prompt_download_model() {
    local model_repo
    model_repo=$(flashmoe_get MODEL_REPO)
    
    echo ""
    echo "=== Model Download Required ==="
    echo ""
    echo "Model not found: $model_repo"
    echo ""
    echo "Would you like to download it from HuggingFace?"
    echo "This may take 30+ minutes depending on your internet connection."
    echo ""
    read -p "Download now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        echo "Downloading model..."
        echo "Command: huggingface-cli download $model_repo"
        huggingface-cli download "$model_repo"
        echo "Download complete."
    else
        echo "Download cancelled. Run 'flashchat' again when ready."
        exit 0
    fi
}

prompt_extract_weights() {
    local weights_dir
    weights_dir=$(flashmoe_get WEIGHTS_DIR)
    
    echo ""
    echo "=== Extract Non-Expert Weights ==="
    echo ""
    echo "We need to extract model weights (~5.5GB) from the HuggingFace model."
    echo "This is a ONE-TIME operation."
    echo ""
    echo "Output: $weights_dir/model_weights.bin"
    echo ""
    read -p "Extract weights now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        cd "$SCRIPT_DIR/metal_infer"
        python3 extract_weights.py --model "$(flashmoe_get MODEL_PATH)" --output "$weights_dir"
        cd "$SCRIPT_DIR"
        echo "Weights extracted successfully."
    else
        echo "Extraction cancelled."
        exit 0
    fi
}

prompt_export_vocab() {
    local weights_dir
    weights_dir=$(flashmoe_get WEIGHTS_DIR)
    local model_path
    model_path=$(flashmoe_get MODEL_PATH)
    
    echo ""
    echo "=== Export Vocabulary ==="
    echo ""
    echo "We need to export the tokenizer vocabulary."
    echo ""
    echo "Output: $weights_dir/vocab.bin"
    echo ""
    read -p "Export vocabulary now? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        cd "$SCRIPT_DIR/metal_infer"
        python3 export_tokenizer.py "$model_path/tokenizer.json" "$weights_dir/vocab.bin"
        cd "$SCRIPT_DIR"
        echo "Vocabulary exported successfully."
    else
        echo "Export cancelled."
        exit 0
    fi
}

prompt_extract_experts() {
    local quantization
    quantization=$(flashmoe_get QUANTIZATION)
    
    echo ""
    echo "=== Extract Expert Weights ==="
    echo ""
    
    local size_4bit="218GB"
    local size_2bit="120GB"
    
    echo "Available disk space:"
    df -h . | tail -1
    echo ""
    
    echo "Choose quantization mode:"
    echo ""
    echo "  [4] 4-bit mode (~$size_4bit) - Full quality, tool calling supported"
    echo "  [2] 2-bit mode (+~$size_2bit, requires 4-bit first) - Faster but breaks tool calling"
    echo "  [Q] Quit"
    echo ""
    
    echo -n "Select option [4/2/Q]: "
    read -r REPLY
    echo ""
    
    local extraction_mode=""
    if [[ "$REPLY" =~ ^[4]$ ]]; then
        extraction_mode="4bit"
    elif [[ $REPLY =~ ^[2]$ ]]; then
        extraction_mode="2bit"
    elif [[ $REPLY =~ ^[Qq]$ ]]; then
        echo "Run './flashchat' again when ready to extract expert weights."
        exit 0
    else
        echo "Invalid option."
        exit 1
    fi
    
    # Update config with selection
    local config_file
    config_file=$(flashmoe_get CONFIG_FILE)
    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        sed -i '' "s/QUANTIZATION=.*/QUANTIZATION=\"$extraction_mode\"/" "$config_file"
    fi
    export FLASHMOE_QUANTIZATION="$extraction_mode"
    
    if [ "$extraction_mode" = "4bit" ]; then
        echo ""
        echo "Extracting 4-bit experts..."
        echo "Estimated time: 30-60 minutes."
        echo ""
        cd "$SCRIPT_DIR"
        python3 repack_experts.py --index ./expert_index.json
        echo "4-bit experts extracted successfully."
    elif [ "$extraction_mode" = "2bit" ]; then
        echo ""
        echo "First extracting 4-bit experts..."
        cd "$SCRIPT_DIR"
        python3 repack_experts.py --index ./expert_index.json
        
        echo ""
        echo "Requantizing to 2-bit..."
        echo "Estimated time: 15-30 minutes."
        echo ""
        cd "$SCRIPT_DIR/metal_infer"
        python3 repack_experts_2bit.py
        echo "2-bit experts created successfully."
    fi
}

prompt_save_config() {
    local config_file
    config_file=$(flashmoe_get CONFIG_FILE)
    
    if [ -n "$config_file" ] && [ -f "$config_file" ]; then
        return  # Already has config
    fi
    
    echo ""
    echo "=== Save Settings? ==="
    echo ""
    echo "Would you like to save these settings to a config file?"
    echo "This allows you to skip these prompts on future runs."
    echo ""
    read -p "Save to config? [Y/n] " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
        flashmoe_create_default_config
        echo "Config saved to ~/.config/flash-moe/config"
    fi
    echo ""
}

ensure_setup() {
    local force="${1:-0}"
    
    set +e  # Temporarily disable exit on error for setup checks
    flashmoe_load_config
    
    logv "Checking setup status..."
    
    # Check model
    if ! check_model_downloaded; then
        prompt_download_model
    fi
    
    # Re-load config after model download (path may have changed)
    flashmoe_load_config
    
    # Check weights
    if ! check_weights_extracted; then
        prompt_extract_weights
    fi
    
    # Check vocab
    if ! check_vocab_exported; then
        prompt_export_vocab
    fi
    
    # Check experts - always prompt if force mode, or if not extracted
    local quantization
    quantization=$(flashmoe_get QUANTIZATION)
    
    if [ "$force" = "1" ]; then
        # Force mode: show current status and offer to re-extract
        echo ""
        echo "=== Expert Weights Status ==="
        echo ""
        echo "Current quantization: $quantization"
        echo ""
        
        if [ "$quantization" = "2bit" ]; then
            if check_experts_2bit_extracted; then
                echo "2-bit experts: extracted"
            else
                echo "2-bit experts: NOT extracted"
            fi
        else
            if check_experts_extracted; then
                echo "4-bit experts: extracted"
            else
                echo "4-bit experts: NOT extracted"
            fi
        fi
        
        echo ""
        read -p "Re-extract experts? [y/N] " -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            prompt_extract_experts
        fi
    elif [ "$quantization" = "2bit" ]; then
        if ! check_experts_2bit_extracted; then
            # For 2bit, we need 4bit first
            if ! check_experts_extracted; then
                prompt_extract_experts
            else
                # 4bit exists, just need 2bit
                cd "$SCRIPT_DIR/metal_infer"
                python3 repack_experts_2bit.py
                cd "$SCRIPT_DIR"
            fi
        fi
    else
        if ! check_experts_extracted; then
            prompt_extract_experts
        fi
    fi
    
    prompt_save_config
    
    logv "Setup complete."
    
    set -e  # Re-enable exit on error
}

# -----------------------------------------------------------------------------
# Server management
# -----------------------------------------------------------------------------

is_server_running() {
    local pid_file
    pid_file=$(flashmoe_get_pid_file)
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

wait_for_server() {
    local port="$1"
    local max_wait=30
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        if nc -z 127.0.0.1 "$port" 2>/dev/null; then
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done
    return 1
}

find_available_port() {
    local start_port="$1"
    local port="$start_port"
    
    while [ $port -lt $((start_port + 10)) ]; do
        if ! nc -z 127.0.0.1 "$port" 2>/dev/null; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    
    echo "$start_port"
    return 1
}

cmd_serve() {
    local stop=0
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stop)
                stop=1
                shift
                ;;
            -p|--port)
                port="$2"
                shift 2
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done
    
    if [ "$stop" -eq 1 ]; then
        # Stop server
        local pid_file
        pid_file=$(flashmoe_get_pid_file)
        
        if [ -f "$pid_file" ]; then
            local pid
            pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                echo "Stopping server (PID: $pid)..."
                kill "$pid"
                rm -f "$pid_file"
                echo "Server stopped."
            else
                echo "Server not running (stale PID file)."
                rm -f "$pid_file"
            fi
        else
            echo "No server running."
        fi
        return
    fi
    
    # Start server
    flashmoe_load_config
    
    local server_port
    server_port="${port:-$(flashmoe_get SERVER_PORT)}"
    
    # Check if WE already started the server
    if is_server_running; then
        echo "Server is already running (PID: $(cat $(flashmoe_get_pid_file))."
        return
    fi
    
    # Check if port is available (may be used by another process)
    if nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Port $server_port is in use by another process."
        local suggested
        suggested=$(find_available_port $((server_port + 1)))
        echo "Suggested available port: $suggested"
        read -p "Use port $suggested instead? [Y/n] " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
            server_port="$suggested"
        else
            error "Cannot start server on port $server_port"
        fi
    fi
    
    # Start server in background
    local pid_file
    pid_file=$(flashmoe_get_pid_file)
    
    cd "$SCRIPT_DIR/metal_infer"
    
    # Set environment for infer
    export FLASHMOE_MODEL_PATH="$(flashmoe_get MODEL_PATH)"
    export FLASHMOE_SERVER_PORT="$server_port"
    
    # Start server
    ./infer --serve "$server_port" &
    local infer_pid=$!
    
    cd "$SCRIPT_DIR"
    
    # Wait for server to be ready
    echo "Starting server on port $server_port..."
    if wait_for_server "$server_port"; then
        echo "$infer_pid" > "$pid_file"
        echo "Server running (PID: $infer_pid)"
        echo "API available at http://127.0.0.1:$server_port"
        echo ""
        echo "Endpoints:"
        echo "  POST /v1/chat/completions"
        echo "  GET  /v1/models"
        echo "  GET  /health"
        echo ""
        echo "To stop: flashchat serve --stop"
    else
        error "Server failed to start"
    fi
}

cmd_chat() {
    local resume_id=""
    local port=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume)
                resume_id="$2"
                shift 2
                ;;
            --port|-p)
                port="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    
    flashmoe_load_config
    
    local server_port
    server_port="${port:-$(flashmoe_get SERVER_PORT)}"
    
    # Start server if not running
    if ! nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Launch chat
    cd "$SCRIPT_DIR/metal_infer"
    
    local chat_args=""
    [ -n "$port" ] && chat_args="--port $port"
    [ -n "$resume_id" ] && chat_args="$chat_args --resume $resume_id"
    
    ./chat $chat_args
    
    cd "$SCRIPT_DIR"
}

cmd_prompt() {
    local prompt="$1"
    
    if [ -z "$prompt" ]; then
        error "Usage: flashchat prompt \"your message here\""
    fi
    
    flashmoe_load_config
    
    local server_port
    server_port=$(flashmoe_get SERVER_PORT)
    
    # Start server if not running
    if ! nc -z 127.0.0.1 "$server_port" 2>/dev/null; then
        echo "Starting server..."
        cmd_serve --port "$server_port"
        echo ""
    fi
    
    # Wait for server
    if ! wait_for_server "$server_port"; then
        error "Server not responding"
    fi
    
    # Send request
    curl -s -N -X POST "http://127.0.0.1:$server_port/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"role\":\"user\",\"content\":\"$prompt\"}],\"max_tokens\":$(flashmoe_get MAX_TOKENS)}"
    echo ""
}

# -----------------------------------------------------------------------------
# Interactive menu
# -----------------------------------------------------------------------------
interactive_menu() {
    while true; do
        flashmoe_load_config
        
        local server_status="Not running"
        if is_server_running; then
            server_status="Running"
        elif nc -z 127.0.0.1 "$(flashmoe_get SERVER_PORT)" 2>/dev/null; then
            server_status="Running (external)"
        fi
        
        # Detect if model is set up
        local setup_status="Not ready"
        if check_model_downloaded && check_weights_extracted && check_vocab_exported && check_experts_extracted; then
            setup_status="Ready"
        fi
        
        echo ""
        echo "=================================================="
        echo "           Flash-MoE Management"
        echo "=================================================="
        echo ""
        echo "Status: $setup_status"
        echo "Model: $(flashmoe_get MODEL_REPO) ($(flashmoe_get QUANTIZATION))"
        echo "Server: $server_status"
        echo ""
        echo "Select an action:"
        echo ""
        echo "  [N] New Chat Session"
        echo "  [R] Resume Chat Session"
        echo "  [S] Start API Server"
        echo "  [T] Stop API Server"
        echo "  [C] Configuration"
        echo "  [L] List Sessions"
        echo "  [V] View Status"
        echo "  [Q] Quit"
        echo ""
        read -p "> " -n 1 -r
        
        case "$REPLY" in
            n|N)
                echo ""
                cmd_chat
                ;;
            r|R)
                echo ""
                echo -n "Enter session ID: "
                read session_id
                if [ -n "$session_id" ]; then
                    cmd_chat --resume "$session_id"
                fi
                ;;
            s|S)
                echo ""
                cmd_serve
                ;;
            t|T)
                echo ""
                cmd_serve --stop
                ;;
            c|C)
                echo ""
                cmd_config
                ;;
            l|L)
                echo ""
                cmd_sessions
                ;;
            v|V)
                echo ""
                cmd_status
                ;;
            q|Q)
                echo ""
                echo "Goodbye!"
                break
                ;;
            *)
                echo ""
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    parse_global_opts "$@"
    
    # If no command, show interactive menu
    if [ $# -eq 0 ]; then
        interactive_menu
        return
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h)
            show_help
            ;;
        status)
            cmd_status "$@"
            ;;
        sessions)
            cmd_sessions "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        chat)
            ensure_setup
            cmd_chat "$@"
            ;;
        serve)
            cmd_serve "$@"
            ;;
        prompt)
            ensure_setup
            cmd_prompt "$@"
            ;;
        *)
            error "Unknown command: $command"
            ;;
    esac
}

main "$@"
